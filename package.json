{
  "name": "simic-systems-home",
  "description": "Trading card storefront at simic.systems",
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "3.7.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/libre-caslon-text": "^5.2.7",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "astro": "^7.0.2",
    "posthog-js": "^1.399.2",
    "posthog-node": "^5.41.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^22.3.0",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260625.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.104.0"
  },
  "scripts": {
    "astro": "astro",
    "build": "astro build && node scripts/patch-sitemap-index.mjs",
    "catalog:plan": "node scripts/sync-stripe-catalog.mjs --dry-run",
    "catalog:pull": "node scripts/pull-stripe-catalog.mjs",
    "catalog:sync": "node scripts/sync-stripe-catalog.mjs && node scripts/set-gtins.mjs --check",
    "catalog:gtin-check": "node scripts/set-gtins.mjs --check",
    "check": "astro build && node scripts/patch-sitemap-index.mjs && node scripts/patch-wrangler-deploy.mjs && tsc && wrangler deploy --config dist/server/wrangler.json --dry-run",
    "deploy": "astro build && node scripts/patch-sitemap-index.mjs && node scripts/patch-wrangler-deploy.mjs && wrangler deploy --config dist/server/wrangler.json",
    "dev": "astro dev",
    "format": "prettier --write 'src/**/*.{ts,tsx,astro,css}'",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "preview": "astro build && node scripts/patch-sitemap-index.mjs && node scripts/patch-wrangler-deploy.mjs && wrangler dev --config dist/server/wrangler.json",
    "slugs:plan": "node scripts/set-slugs.mjs",
    "slugs:sync": "node scripts/set-slugs.mjs slugs.json",
    "test": "vitest run",
    "webhook:resend": "node scripts/resend-failed-webhooks.mjs",
    "webhook:resend:dry": "node scripts/resend-failed-webhooks.mjs --dry-run",
    "types": "wrangler types"
  },
  "type": "module",
  "overrides": {
    "undici": "^7.24.0",
    "devalue": "^5.8.1",
    "flatted": "^3.4.2",
    "h3": "^1.15.9",
    "wrangler": "$wrangler"
  }
}
