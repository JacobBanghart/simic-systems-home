---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Shipping Policy - ${SITE_TITLE}`} description="Simic Systems ships factory-sealed Magic: The Gathering products via USPS within the US. Orders processed in 1–3 business days. All sales are final." />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": "Shipping Policy",
			"url": "https://simic.systems/shipping/",
			"description": "Shipping policy for Simic Systems. US shipping only. All sales final.",
			"mainEntity": [
				{
					"@type": "MerchantReturnPolicy",
					"name": "Simic Systems Return Policy",
					"returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
					"applicableCountry": "US",
					"description": "All sales are final. We do not accept returns except in the case of damaged or incorrect orders."
				},
				{
					"@type": "ShippingDeliveryTime",
					"businessDays": {
						"@type": "OpeningHoursSpecification",
						"dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"]
					},
					"handlingTime": {
						"@type": "QuantitativeValue",
						"minValue": 1,
						"maxValue": 3,
						"unitCode": "DAY"
					},
					"transitTime": {
						"@type": "QuantitativeValue",
						"minValue": 3,
						"maxValue": 7,
						"unitCode": "DAY"
					}
				}
			]
		})}></script>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<h1>Shipping Policy</h1>

				<h2>Shipping</h2>
				<p>
					We currently ship to addresses within the <strong>United States</strong> only. Orders are shipped via USPS.
				</p>
				<ul>
					<li>Orders are typically processed and shipped within 1–3 business days.</li>
					<li>You will receive a shipping confirmation email with tracking information once your order has shipped.</li>
					<li>Delivery times vary by location but generally take 3–7 business days after shipment.</li>
				</ul>

				<h2>Return Policy</h2>
				<p>
					<strong>All sales are final.</strong> Due to the nature of factory-sealed trading card products, we do not accept returns.
				</p>

				<h2>Damaged or Incorrect Orders</h2>
				<p>
					If your order arrives damaged or you receive the wrong item, please contact us within 7 days of delivery at <a href="mailto:contact@simic.systems">contact@simic.systems</a>. Include photos of the issue and your order number, and we'll make it right.
				</p>

				<p>
					Questions about shipping? <a href="/contact/">Contact us</a>.
				</p>
			</article>
		</main>
		<Footer />
	</body>
</html>
<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 1rem 1.5rem;
	}
	article h1 {
		margin-bottom: 1rem;
	}
	article h2 {
		margin-top: 2rem;
		margin-bottom: 0.5rem;
	}
	ul {
		margin-bottom: 1.5em;
	}
	li {
		margin-bottom: 0.5em;
	}
</style>
