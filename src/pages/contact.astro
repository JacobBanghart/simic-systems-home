---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ContactForm } from '../components/ContactForm';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Contact - ${SITE_TITLE}`} description="Contact Simic Systems with questions about your order or products. Email contact@simic.systems or use the contact form." />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "ContactPage",
			"name": "Contact Simic Systems",
			"url": "https://simic.systems/contact/",
			"description": "Contact Simic Systems for order questions and product inquiries.",
			"mainEntity": {
				"@type": "Organization",
				"name": "Simic Systems LLC",
				"url": "https://simic.systems",
				"logo": "https://simic.systems/favicon.svg",
				"email": "contact@simic.systems",
				"telephone": "+16055534735",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "5115 Lankershim Blvd Apt 210",
					"addressLocality": "North Hollywood",
					"addressRegion": "CA",
					"postalCode": "91601",
					"addressCountry": "US"
				}
			}
		})}></script>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<h1>Contact Us</h1>
				<p>
					Have a question about an order, a product, or anything else? Fill out the form below or email us directly at
					<a href="mailto:contact@simic.systems">contact@simic.systems</a>.
				</p>

				<ContactForm client:load />

				<h2>Order Issues</h2>
				<p>
					If you have a problem with an order (damaged item, wrong product, shipping question), please include:
				</p>
				<ul>
					<li>Your order number or Stripe receipt email</li>
					<li>A description of the issue</li>
					<li>Photos, if applicable (damaged packaging, wrong item, etc.)</li>
				</ul>

				<h2>Damaged or Incorrect Orders</h2>
				<p>
					All sales are final on factory-sealed products. If your order arrived damaged or with the wrong item, include photos and your order number in your message above. See our <a href="/shipping/">Shipping & Returns</a> page for full policy details.
				</p>
			</article>
		</main>
		<Footer />
	</body>
</html>
<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 1rem 1.5rem;
	}
	article h1 {
		margin-bottom: 1rem;
	}
	article h2 {
		margin-top: 2rem;
		margin-bottom: 0.5rem;
	}
	ul {
		margin-bottom: 1.5em;
	}
	li {
		margin-bottom: 0.5em;
	}
</style>
