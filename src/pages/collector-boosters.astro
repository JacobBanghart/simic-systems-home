---
export const prerender = false;

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";
import { fetchStoreProducts } from "../lib/stripeProducts";
import { optimizeProductImage } from "../lib/optimizeProductImage";
import { formatPrice } from "../lib/format";
import { env } from "cloudflare:workers";

const products = await fetchStoreProducts(env);

const collectorBoostersRaw = products.filter((p) =>
  p.name.toLowerCase().includes("collector booster")
);
const collectorBoosters = await Promise.all(
  collectorBoostersRaw.map(async (p) => ({
    ...p,
    imageOptimized: p.image ? await optimizeProductImage(p.image, 300) : p.image,
  }))
);

const pageTitle = `Buy MTG Collector Booster Displays | ${SITE_TITLE}`;
const pageDescription =
  "Shop factory-sealed Magic: The Gathering Collector Booster Displays at Simic Systems. Premium foils, extended arts, and special treatments. Secure checkout, US shipping via USPS.";

const categorySchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  description: pageDescription,
  url: "https://simic.systems/collector-boosters/",
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://simic.systems/" },
      { "@type": "ListItem", position: 2, name: "Collector Boosters", item: "https://simic.systems/collector-boosters/" },
    ],
  },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: collectorBoosters.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `https://simic.systems/product/${product.slug ?? product.id}/`,
    })),
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <script type="application/ld+json" nonce={Astro.locals.nonce} set:html={JSON.stringify(categorySchema)} />
  </head>
  <body>
    <Header />
    <main class="category-page">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="/">Store</a>
        <span aria-hidden="true">›</span>
        <span>Collector Boosters</span>
      </nav>

      <h1>MTG Collector Booster Displays</h1>

      <p class="category-intro">
        Collector Booster Displays are the premium sealed product for Magic: The Gathering.
        Each box contains 12 packs loaded with foils, extended-art cards, borderless treatments,
        and set-specific special finishes, with every pack guaranteed to contain multiple rares or
        mythic rares and at least one foil rare or better.
      </p>

      {collectorBoosters.length === 0 ? (
        <p class="empty-state">No Collector Booster Displays currently in stock. <a href="/">View all products</a> or <a href="/contact/">contact us</a> to be notified when stock arrives.</p>
      ) : (
        <div class="product-grid">
          {collectorBoosters.map((product) => {
            const outOfStock = product.quantity <= 0;
            const productUrl = `/product/${product.slug ?? product.id}/`;
            const rawName = (() => {
              const m = product.name.match(/ \([A-Z0-9]{2,5}\)\s*$/u);
              return m ? product.name.slice(0, m.index).trim() : product.name.trim();
            })();
            const firstDash = rawName.indexOf(" - ");
            const setName = firstDash >= 0 ? rawName.slice(0, firstDash).trim() : rawName;
            const displayName = setName + " Collector Boosters";
            return (
              <a href={productUrl} class={`product-card${outOfStock ? " out-of-stock" : ""}`}>
                {product.image && (
                  <img
                    src={product.imageOptimized}
                    alt={displayName}
                    width={300}
                    height={300}
                    loading="lazy"
                  />
                )}
                <div class="card-body">
                  <p class="card-name">{displayName}</p>
                  <p class="card-price">{formatPrice(product.price)}</p>
                  <p class={`card-stock${outOfStock ? " oos" : product.quantity <= 3 ? " low" : ""}`}>
                    {outOfStock ? "Out of stock" : product.quantity <= 3 ? `Only ${product.quantity} left` : `${product.quantity} available`}
                  </p>
                </div>
              </a>
            );
          })}
        </div>
      )}

      <div class="category-guide">
        <h2>Collector Boosters vs. Play Boosters: which should you buy?</h2>
        <p>
          The two product lines exist for different reasons. Play Boosters are built for
          drafting, sealed events, and building a deck out of what you open, at a lower
          per-pack cost and a lower foil/rare density. Collector Boosters drop the
          "gameplay economy" entirely and load every pack with the best-looking version of
          every card: guaranteed foils, extended art, and showcase frames that show up rarely
          or not at all in Play Boosters. You pay a premium per card for that concentration.
        </p>
        <div class="compare-table-wrap">
          <table class="compare-table">
            <thead>
              <tr><th scope="col"></th><th scope="col">Collector Boosters</th><th scope="col">Play Boosters</th></tr>
            </thead>
            <tbody>
              <tr><th scope="row">Best for</th><td>Collectors, display pieces, gifting</td><td>Drafting, sealed play, deck-building</td></tr>
              <tr><th scope="row">Foils</th><td>Guaranteed in every pack, often several</td><td>At least one per pack</td></tr>
              <tr><th scope="row">Rares/mythics</th><td>Multiple guaranteed per pack</td><td>One guaranteed per pack</td></tr>
              <tr><th scope="row">Card treatments</th><td>Extended art, borderless, showcase frames</td><td>Standard frame, occasional showcase</td></tr>
              <tr><th scope="row">Price per pack</th><td>Higher</td><td>Lower</td></tr>
              <tr><th scope="row">Good for cracking and playing that night?</th><td>Built for value and display, not deck-filling commons</td><td>Yes, that's the format's whole design intent</td></tr>
            </tbody>
          </table>
        </div>
        <p>
          Still not sure which to buy? Reach for <a href="/play-boosters/">Play Boosters</a>
          if you want a draft night, a Standard deck, or the most cards per dollar. Reach for
          Collector Boosters if you want display-quality foils, a specific chase card, or a gift
          for someone who already has the cards and wants the good-looking version of them.
        </p>
        <h2>Factory-sealed and sourced</h2>
        <p>
          Every display we sell ships factory-sealed in its original manufacturer packaging and
          is sourced from authorized Wizards of the Coast distributors. We don't sell
          repackaged, reconstructed, or previously-opened product. If anything arrives damaged
          or tampered with in transit, <a href="/contact/">contact us</a> within 7 days with
          photos and your order number and we'll make it right. Full policy details are on our
          <a href="/faq/">FAQ page</a>.
        </p>
      </div>

      <p class="see-all">Looking for Play Boosters? <a href="/play-boosters/">Browse Play Booster Displays →</a></p>
    </main>
    <Footer />
  </body>
</html>

<style>
  .category-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem 3rem;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: rgb(var(--gray));
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .breadcrumb a { color: rgb(var(--gray)); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }

  h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .category-intro {
    font-size: 1rem;
    line-height: 1.7;
    color: rgb(var(--gray-dark));
    max-width: 760px;
    margin-bottom: 2rem;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: rgb(var(--gray-dark));
    transition: border-color 0.15s;
  }
  .product-card:hover { border-color: var(--accent); }
  .product-card.out-of-stock { opacity: 0.6; }

  .product-card img {
    width: 100%;
    height: 200px;
    object-fit: contain;
    padding: 0.75rem;
    box-sizing: border-box;
    background: var(--bg-secondary);
  }

  .card-body { padding: 0.75rem; }

  .card-name {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 0.4rem;
  }

  .card-price {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.3rem;
  }

  .card-stock {
    font-size: 0.78rem;
    color: rgb(var(--gray));
    margin: 0;
  }
  .card-stock.oos { color: #d32f2f; }
  .card-stock.low { color: #e65100; font-weight: 600; }

  .empty-state {
    color: rgb(var(--gray));
    margin-bottom: 2rem;
  }

  .category-guide {
    max-width: 760px;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .category-guide h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 1.75rem 0 0.75rem;
  }
  .category-guide h2:first-child { margin-top: 0; }
  .category-guide p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgb(var(--gray-dark));
    margin-bottom: 0.9rem;
  }
  .category-guide a { color: var(--accent); }

  .compare-table-wrap {
    overflow-x: auto;
    margin-bottom: 1rem;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    min-width: 420px;
  }
  .compare-table th,
  .compare-table td {
    padding: 0.6rem 0.85rem;
    text-align: left;
    border-bottom: 1px solid rgb(var(--gray-light));
  }
  .compare-table thead th {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgb(var(--gray));
    background: var(--bg-secondary);
  }
  .compare-table tbody th {
    font-weight: 600;
    color: rgb(var(--gray-dark));
    white-space: nowrap;
  }
  .compare-table tr:last-child td,
  .compare-table tr:last-child th {
    border-bottom: none;
  }

  .see-all {
    font-size: 0.9rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .see-all a { color: var(--accent); }
</style>
