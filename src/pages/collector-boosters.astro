---
export const prerender = false;

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";
import { fetchStoreProducts } from "../lib/stripeProducts";
import { formatPrice } from "../lib/format";
import { extractSetName } from "../lib/productDisplay";
import { env } from "cloudflare:workers";
import type { ProductData } from "../types";

let products: ProductData[] = [];
try {
  products = await fetchStoreProducts(env);
} catch (error) {
  console.error("Failed to fetch products from Stripe:", error);
}

// Grid thumbnails use the raw Stripe image directly rather than running every
// product through optimizeProductImage() in parallel — fanning that out
// across a whole category (5+ products at once) was tripping a Cloudflare
// resource limit that took the entire page down with an uncaught 500,
// since a hard isolate-level failure isn't something a per-image try/catch
// inside optimizeProductImage() can always catch.
const collectorBoosters = products.filter((p) =>
  p.name.toLowerCase().includes("collector booster")
);

// Precomputed here rather than inline in the .map() below — the astro
// template parser misreads a `<=` comparison sitting in statement position
// inside a JSX expression's arrow-function block body as the start of a tag,
// throwing a bogus "Fragment shorthand syntax" parse error (astro-eslint-parser
// 2.1.0). Plain frontmatter script isn't affected, only the JSX-aware scanner is.
const collectorBoosterCards = collectorBoosters.map((product) => {
  const outOfStock = product.quantity <= 0;
  const lowStock = !outOfStock && product.quantity <= 3;
  const productUrl = `/product/${product.slug ?? product.id}/`;
  const displayName = extractSetName(product.name) + " Collector Boosters";
  const stockText = outOfStock
    ? "Out of stock"
    : lowStock
    ? `Only ${product.quantity} left`
    : `${product.quantity} available`;
  const stockClass = outOfStock ? " oos" : lowStock ? " low" : "";
  return { product, outOfStock, productUrl, displayName, stockText, stockClass };
});

const pageTitle = `Buy MTG Collector Booster Displays | ${SITE_TITLE}`;
const pageDescription =
  "Shop factory-sealed Magic: The Gathering Collector Booster Displays at Simic Systems. Premium foils, extended arts, and special treatments. Secure checkout, US shipping via USPS.";

const categorySchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  description: pageDescription,
  url: "https://simic.systems/collector-boosters/",
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://simic.systems/" },
      { "@type": "ListItem", position: 2, name: "Collector Boosters", item: "https://simic.systems/collector-boosters/" },
    ],
  },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: collectorBoosters.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `https://simic.systems/product/${product.slug ?? product.id}/`,
    })),
  },
};

const nonce = Astro.locals.nonce;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <script type="application/ld+json" nonce={nonce} set:html={JSON.stringify(categorySchema)} />
  </head>
  <body>
    <Header />
    <main class="category-page">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="/">Store</a>
        <span aria-hidden="true">›</span>
        <span>Collector Boosters</span>
      </nav>

      <h1>MTG Collector Booster Displays</h1>
      <p class="last-updated"><em>Last updated: July 13, 2026</em></p>

      <p class="category-intro">
        Collector Booster Displays are the premium sealed product for Magic: The Gathering.
        Each box contains 12 packs loaded with foils, extended-art cards, borderless treatments,
        and set-specific special finishes, with every pack guaranteed to contain multiple rares or
        mythic rares and at least one foil rare or better.
      </p>

      {collectorBoosters.length === 0 ? (
        <p class="empty-state">No Collector Booster Displays currently in stock. <a href="/">View all products</a> or <a href="/contact/">contact us</a> to be notified when stock arrives.</p>
      ) : (
        <div class="product-grid">
          {collectorBoosterCards.map(({ product, outOfStock, productUrl, displayName, stockText, stockClass }) => (
            <a href={productUrl} class={`product-card${outOfStock ? " out-of-stock" : ""}`}>
              {product.image && (
                <img
                  src={product.image}
                  alt={displayName}
                  width={300}
                  height={300}
                  loading="lazy"
                />
              )}
              <div class="card-body">
                <p class="card-name">{displayName}</p>
                <p class="card-price">{formatPrice(product.price)}</p>
                <p class={`card-stock${stockClass}`}>{stockText}</p>
              </div>
            </a>
          ))}
        </div>
      )}

      <div class="category-guide">
        <h2>Collector Boosters vs. Play Boosters: which should you buy?</h2>
        <p>
          The two product lines exist for different reasons. Play Boosters are built for
          drafting, sealed events, and building a deck out of what you open, at a lower
          per-pack cost and a lower foil/rare density. Collector Boosters drop the
          "gameplay economy" entirely and load every pack with the best-looking version of
          every card: guaranteed foils, extended art, and showcase frames that show up rarely
          or not at all in Play Boosters. You pay a premium per card for that concentration.
        </p>
        <div class="compare-table-wrap">
          <table class="compare-table">
            <thead>
              <tr><th scope="col"></th><th scope="col">Collector Boosters</th><th scope="col">Play Boosters</th></tr>
            </thead>
            <tbody>
              <tr><th scope="row">Best for</th><td>Collectors, display pieces, gifting</td><td>Drafting, sealed play, deck-building</td></tr>
              <tr><th scope="row">Foils</th><td>Guaranteed in every pack, often several</td><td>At least one per pack</td></tr>
              <tr><th scope="row">Rares/mythics</th><td>Multiple guaranteed per pack</td><td>One guaranteed per pack</td></tr>
              <tr><th scope="row">Card treatments</th><td>Extended art, borderless, showcase frames</td><td>Standard frame, occasional showcase</td></tr>
              <tr><th scope="row">Price per pack</th><td>Higher</td><td>Lower</td></tr>
              <tr><th scope="row">Good for cracking and playing that night?</th><td>Built for value and display, not deck-filling commons</td><td>Yes, that's the format's whole design intent</td></tr>
            </tbody>
          </table>
        </div>
        <p>
          Still not sure which to buy? Reach for <a href="/play-boosters/">Play Boosters</a>
          if you want a draft night, a Standard deck, or the most cards per dollar. Reach for
          Collector Boosters if you want display-quality foils, a specific chase card, or a gift
          for someone who already has the cards and wants the good-looking version of them.
        </p>
        <h2>Factory-sealed and sourced</h2>
        <p>
          Every Collector Booster Display we sell ships factory-sealed in its original
          manufacturer packaging and is sourced from authorized Wizards of the Coast
          distributors — never a repackaged, reconstructed, or previously-opened box. Given
          the premium foils and chase cards riding on that seal, we check it before it ships.
          If anything arrives damaged or tampered with in transit, <a href="/contact/">contact us</a>
          within 7 days with photos and your order number and we'll make it right. Full policy
          details are on our <a href="/faq/">FAQ page</a>.
        </p>
      </div>

      <p class="see-all">Looking for Play Boosters? <a href="/play-boosters/">Browse Play Booster Displays →</a></p>
    </main>
    <Footer />
  </body>
</html>

<style>
  .category-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem 3rem;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: rgb(var(--gray));
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .breadcrumb a { color: rgb(var(--gray)); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }

  h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .last-updated {
    font-size: 0.8rem;
    color: rgb(var(--gray));
    margin-bottom: 1rem;
  }

  .category-intro {
    font-size: 1rem;
    line-height: 1.7;
    color: rgb(var(--gray-dark));
    max-width: 760px;
    margin-bottom: 2rem;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: rgb(var(--gray-dark));
    transition: border-color 0.15s;
  }
  .product-card:hover { border-color: var(--accent); }
  .product-card.out-of-stock { opacity: 0.6; }

  .product-card img {
    width: 100%;
    height: 200px;
    object-fit: contain;
    padding: 0.75rem;
    box-sizing: border-box;
    background: var(--bg-secondary);
  }

  .card-body { padding: 0.75rem; }

  .card-name {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 0.4rem;
  }

  .card-price {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.3rem;
  }

  .card-stock {
    font-size: 0.78rem;
    color: rgb(var(--gray));
    margin: 0;
  }
  /* #ff6659 rather than the more common Material red #d32f2f — against this
     theme's dark background (#0d1513) #d32f2f computes to ~3.72:1 contrast,
     below WCAG AA's 4.5:1 minimum for normal text; #ff6659 clears ~6.4:1. */
  .card-stock.oos { color: #ff6659; }
  .card-stock.low { color: #e65100; font-weight: 600; }

  .empty-state {
    color: rgb(var(--gray));
    margin-bottom: 2rem;
  }

  .category-guide {
    max-width: 760px;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .category-guide h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 1.75rem 0 0.75rem;
  }
  .category-guide h2:first-child { margin-top: 0; }
  .category-guide p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgb(var(--gray-dark));
    margin-bottom: 0.9rem;
  }
  .category-guide a { color: var(--accent); text-decoration: underline; }

  .compare-table-wrap {
    overflow-x: auto;
    margin-bottom: 1rem;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    min-width: 420px;
  }
  .compare-table th,
  .compare-table td {
    padding: 0.6rem 0.85rem;
    text-align: left;
    border-bottom: 1px solid rgb(var(--gray-light));
  }
  .compare-table thead th {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgb(var(--gray));
    background: var(--bg-secondary);
  }
  .compare-table tbody th {
    font-weight: 600;
    color: rgb(var(--gray-dark));
    white-space: nowrap;
  }
  .compare-table tr:last-child td,
  .compare-table tr:last-child th {
    border-bottom: none;
  }

  .see-all {
    font-size: 0.9rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .see-all a { color: var(--accent); text-decoration: underline; }
</style>
