---
export const prerender = false;

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";
import { fetchStoreProducts } from "../lib/stripeProducts";
import { formatPrice } from "../lib/format";
import { extractSetName } from "../lib/productDisplay";
import { env } from "cloudflare:workers";
import type { ProductData } from "../types";

let products: ProductData[] = [];
try {
  products = await fetchStoreProducts(env);
} catch (error) {
  console.error("Failed to fetch products from Stripe:", error);
}

// Grid thumbnails use the raw Stripe image directly rather than running every
// product through optimizeProductImage() in parallel — fanning that out
// across a whole category (9+ products at once) was tripping a Cloudflare
// resource limit that took the entire page down with an uncaught 500,
// since a hard isolate-level failure isn't something a per-image try/catch
// inside optimizeProductImage() can always catch.
const playBoosters = products.filter((p) =>
  p.name.toLowerCase().includes("play booster") ||
  p.name.toLowerCase().includes("jumpstart booster")
);

// Precomputed here rather than inline in the .map() below — the astro
// template parser misreads a `<=` comparison sitting in statement position
// inside a JSX expression's arrow-function block body as the start of a tag,
// throwing a bogus "Fragment shorthand syntax" parse error (astro-eslint-parser
// 2.1.0). Plain frontmatter script isn't affected, only the JSX-aware scanner is.
const playBoosterCards = playBoosters.map((product) => {
  const outOfStock = product.quantity <= 0;
  const lowStock = !outOfStock && product.quantity <= 3;
  const productUrl = `/product/${product.slug ?? product.id}/`;
  const displayName = extractSetName(product.name) + " Play Boosters";
  const stockText = outOfStock
    ? "Out of stock"
    : lowStock
    ? `Only ${product.quantity} left`
    : `${product.quantity} available`;
  const stockClass = outOfStock ? " oos" : lowStock ? " low" : "";
  return { product, outOfStock, productUrl, displayName, stockText, stockClass };
});

const pageTitle = `Buy MTG Play Booster Displays | ${SITE_TITLE}`;
const pageDescription =
  "Shop factory-sealed Magic: The Gathering Play Booster Displays at Simic Systems. The current standard booster for drafting and opening, with a guaranteed rare or better per pack. Secure checkout, US shipping via USPS.";

const categorySchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  description: pageDescription,
  url: "https://simic.systems/play-boosters/",
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://simic.systems/" },
      { "@type": "ListItem", position: 2, name: "Play Boosters", item: "https://simic.systems/play-boosters/" },
    ],
  },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: playBoosters.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `https://simic.systems/product/${product.slug ?? product.id}/`,
    })),
  },
};

const nonce = Astro.locals.nonce;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <script type="application/ld+json" nonce={nonce} set:html={JSON.stringify(categorySchema)} />
  </head>
  <body>
    <Header />
    <main class="category-page">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="/">Store</a>
        <span aria-hidden="true">›</span>
        <span>Play Boosters</span>
      </nav>

      <h1>MTG Play Booster Displays</h1>
      <p class="last-updated"><em>Last updated: July 13, 2026</em></p>

      <p class="category-intro">
        Play Booster Displays are the current standard sealed product for Magic: The Gathering,
        replacing Draft and Set Boosters in 2024. Most displays contain 30 packs with 14 cards
        each, including at least one rare or mythic rare per pack and a chance at foils, special
        art variants, and The List cards — Foundations is the one exception, shipping in a
        36-pack display. Play Boosters work for both drafting and collection building.
      </p>

      {playBoosters.length === 0 ? (
        <p class="empty-state">No Play Booster Displays currently in stock. <a href="/">View all products</a> or <a href="/contact/">contact us</a> to be notified when stock arrives.</p>
      ) : (
        <div class="product-grid">
          {playBoosterCards.map(({ product, outOfStock, productUrl, displayName, stockText, stockClass }) => (
            <a href={productUrl} class={`product-card${outOfStock ? " out-of-stock" : ""}`}>
              {product.image && (
                <img
                  src={product.image}
                  alt={displayName}
                  width={300}
                  height={300}
                  loading="lazy"
                />
              )}
              <div class="card-body">
                <p class="card-name">{displayName}</p>
                <p class="card-price">{formatPrice(product.price)}</p>
                <p class={`card-stock${stockClass}`}>{stockText}</p>
              </div>
            </a>
          ))}
        </div>
      )}

      <div class="category-guide">
        <h2>Play Boosters vs. Collector Boosters: which should you buy?</h2>
        <p>
          Play Boosters are built for drafting, sealed events, and building a deck out
          of what you open, at a lower per-pack cost and a lower foil/rare density than the
          alternative. Collector Boosters drop the "gameplay economy" entirely and load every
          pack with the best-looking version of every card: guaranteed foils, extended art, and
          showcase frames. That trade-off, lower cost against lighter treatments, is the whole
          point of the format.
        </p>
        <div class="compare-table-wrap">
          <table class="compare-table">
            <thead>
              <tr><th scope="col"></th><th scope="col">Play Boosters</th><th scope="col">Collector Boosters</th></tr>
            </thead>
            <tbody>
              <tr><th scope="row">Best for</th><td>Drafting, sealed play, deck-building</td><td>Collectors, display pieces, gifting</td></tr>
              <tr><th scope="row">Foils</th><td>At least one per pack</td><td>Guaranteed in every pack, often several</td></tr>
              <tr><th scope="row">Rares/mythics</th><td>One guaranteed per pack</td><td>Multiple guaranteed per pack</td></tr>
              <tr><th scope="row">Card treatments</th><td>Standard frame, occasional showcase</td><td>Extended art, borderless, showcase frames</td></tr>
              <tr><th scope="row">Price per pack</th><td>Lower</td><td>Higher</td></tr>
              <tr><th scope="row">Good for cracking and playing that night?</th><td>Yes, that's the format's whole design intent</td><td>Built for value and display, not deck-filling commons</td></tr>
            </tbody>
          </table>
        </div>
        <p>
          Still not sure which to buy? Reach for Play Boosters if you want a draft night, a
          Standard deck, or the most cards per dollar. Reach for
          <a href="/collector-boosters/">Collector Boosters</a> if you want display-quality
          foils, a specific chase card, or a gift for someone who already has the cards and wants
          the good-looking version of them.
        </p>
        <h2>Factory-sealed and sourced</h2>
        <p>
          Every Play Booster Display we sell ships factory-sealed in its original manufacturer
          packaging and is sourced from authorized Wizards of the Coast distributors — never a
          repackaged, reconstructed, or previously-opened box. That sourcing discipline matters
          most on high-volume draft product like this, where a single relabeled box can throw
          off an entire event. If anything arrives damaged or tampered with in transit,
          <a href="/contact/">contact us</a> within 7 days with photos and your order number and
          we'll make it right. Full policy details are on our <a href="/faq/">FAQ page</a>.
        </p>
      </div>

      <p class="see-all">Looking for premium foils? <a href="/collector-boosters/">Browse Collector Booster Displays →</a></p>
    </main>
    <Footer />
  </body>
</html>

<style>
  .category-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem 3rem;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: rgb(var(--gray));
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .breadcrumb a { color: rgb(var(--gray)); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }

  h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .last-updated {
    font-size: 0.8rem;
    color: rgb(var(--gray));
    margin-bottom: 1rem;
  }

  .category-intro {
    font-size: 1rem;
    line-height: 1.7;
    color: rgb(var(--gray-dark));
    max-width: 760px;
    margin-bottom: 2rem;
  }

  /* On mobile, an unclamped multi-paragraph intro can push the entire
     product grid below the fold. Clamp to the first paragraph and let the
     rest read as supporting detail beneath it. */
  @media (max-width: 640px) {
    .category-intro-lead {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-bottom: 0.75rem;
    }
    .category-intro-more {
      font-size: 0.9rem;
    }
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: rgb(var(--gray-dark));
    transition: border-color 0.15s;
  }
  .product-card:hover { border-color: var(--accent); }
  .product-card.out-of-stock { opacity: 0.6; }

  .product-card img {
    width: 100%;
    height: 200px;
    object-fit: contain;
    padding: 0.75rem;
    box-sizing: border-box;
    background: var(--bg-secondary);
  }

  .card-body { padding: 0.75rem; }

  .card-name {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 0.4rem;
  }

  .card-price {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.3rem;
  }

  .card-stock {
    font-size: 0.78rem;
    color: rgb(var(--gray));
    margin: 0;
  }
  .card-stock.oos { color: #d32f2f; }
  .card-stock.low { color: #e65100; font-weight: 600; }

  .empty-state {
    color: rgb(var(--gray));
    margin-bottom: 2rem;
  }

  .category-guide {
    max-width: 760px;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .category-guide h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 1.75rem 0 0.75rem;
  }
  .category-guide h2:first-child { margin-top: 0; }
  .category-guide p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgb(var(--gray-dark));
    margin-bottom: 0.9rem;
  }
  .category-guide a { color: var(--accent); }

  .compare-table-wrap {
    overflow-x: auto;
    margin-bottom: 1rem;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    min-width: 420px;
  }
  .compare-table th,
  .compare-table td {
    padding: 0.6rem 0.85rem;
    text-align: left;
    border-bottom: 1px solid rgb(var(--gray-light));
  }
  .compare-table thead th {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgb(var(--gray));
    background: var(--bg-secondary);
  }
  .compare-table tbody th {
    font-weight: 600;
    color: rgb(var(--gray-dark));
    white-space: nowrap;
  }
  .compare-table tr:last-child td,
  .compare-table tr:last-child th {
    border-bottom: none;
  }

  .see-all {
    font-size: 0.9rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .see-all a { color: var(--accent); }
</style>
