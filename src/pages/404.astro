---
export const prerender = false;

import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

// Requires prerender = false: a static/prerendered page can't carry a
// non-200 status. Routes that don't find a resource use Astro.rewrite("/404")
// (see src/pages/product/[slug].astro) so this status applies to them too,
// instead of a redirect that would otherwise land on a 200 response.
Astro.response.status = 404;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Page Not Found - ${SITE_TITLE}`} description="The page you're looking for doesn't exist." robots="noindex, nofollow" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Page Not Found</h1>
			<p>Sorry, the page you're looking for doesn't exist or has been moved.</p>
			<a href="/">Back to Store</a>
		</main>
		<Footer />
	</body>
</html>
<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
		text-align: center;
	}
	h1 {
		margin-bottom: 1rem;
	}
	p {
		margin-bottom: 2rem;
		color: var(--gray);
	}
	a {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background: var(--accent);
		color: white;
		text-decoration: none;
		border-radius: 4px;
	}
	a:hover {
		opacity: 0.9;
	}
</style>
