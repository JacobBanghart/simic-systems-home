---
export const prerender = false;

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { MainPage } from "../components/MainPage";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { fetchStoreProducts } from "../lib/stripeProducts";
import type { ProductData } from "../types";
import { env } from "cloudflare:workers";

const homeTitle = `Buy Sealed MTG Booster Boxes & Packs | ${SITE_TITLE}`;

let products: ProductData[] = [];

try {
  products = await fetchStoreProducts(env);
} catch (error) {
  console.error("Failed to fetch products from Stripe:", error);
}

const productListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: homeTitle,
  description: SITE_DESCRIPTION,
  url: Astro.url.href,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: products.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: new URL(`/product/${product.slug ?? product.id}/`, Astro.site).href,
      item: {
        "@type": "Product",
        name: product.name,
        description: product.description,
        image: product.image ? [product.image] : undefined,
        category: product.category,
        offers: {
          "@type": "Offer",
          priceCurrency: "USD",
          price: (product.price / 100).toFixed(2),
          availability:
            product.quantity > 0
              ? "https://schema.org/InStock"
              : "https://schema.org/OutOfStock",
          url: new URL(`/product/${product.slug ?? product.id}/`, Astro.site).href,
        },
      },
    })),
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Simic Systems",
  url: "https://simic.systems/",
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Simic Systems",
  legalName: "Simic Systems LLC",
  url: "https://simic.systems/",
  logo: "https://simic.systems/logo.png",
  email: "contact@simic.systems",
  telephone: "+16055534735",
  address: {
    "@type": "PostalAddress",
    streetAddress: "5115 Lankershim Blvd Apt 210",
    addressLocality: "North Hollywood",
    addressRegion: "CA",
    postalCode: "91601",
    addressCountry: "US",
  },
};
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={homeTitle} description={SITE_DESCRIPTION} />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(productListSchema)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(websiteSchema)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(organizationSchema)}
        />
    </head>
    <body>
        <Header showCart />
        <main>
            <img
                src="/banner.webp"
                alt="Simic Systems — Trading Card Products"
                width={1536}
                height={1024}
                fetchpriority="high"
                class="store-banner"
            />
            <h1 class="store-title">Buy Sealed Magic: The Gathering Products Online</h1>
            <MainPage client:load products={products} />
            <section class="trust-section">
                <div class="trust-badges">
                    <div class="trust-badge">
                        <span class="badge-icon">🔒</span>
                        <span>Secure checkout via Stripe</span>
                    </div>
                    <div class="trust-badge">
                        <span class="badge-icon">📦</span>
                        <span>Ships USPS Ground Advantage</span>
                    </div>
                    <div class="trust-badge">
                        <span class="badge-icon">✅</span>
                        <span>Factory-sealed product only</span>
                    </div>
                    <div class="trust-badge">
                        <span class="badge-icon">🇺🇸</span>
                        <span>US shipping only</span>
                    </div>
                </div>
                <div class="reviews-placeholder">
                    <h2 class="reviews-heading">Customer Reviews</h2>
                    <p class="reviews-empty">Simic Systems is a new store — no reviews yet. If you've ordered from us, we'd love a <a href="https://g.page/r/simic-systems/review" rel="noopener">Google Review</a>.</p>
                </div>
            </section>
            <div class="seo-copy">
                <p>Simic Systems is an online trading card game store specializing in factory sealed MTG products. Browse our selection of Magic: The Gathering booster boxes, collector boxes, play boosters, draft boosters, bundles, and commander decks — all authentic and officially licensed.</p>
                <p>Every order ships with secure checkout powered by Stripe, with shipping available across the United States. Check back regularly for new set releases, restocks, and pre-orders.</p>
                <p>Looking for booster packs, set boosters, or collector boxes at competitive prices? Shop our full catalog above and add items to your cart for fast, reliable shipping.</p>
            </div>
        </main>
        <Footer />
    </body>
</html>

<style>
    .store-banner {
        width: 100%;
        max-height: 220px;
        object-fit: cover;
        object-position: center 20%;
        display: block;
        border-radius: 0;
    }

    .store-title {
        font-size: 1rem;
        font-weight: 600;
        color: rgb(var(--gray));
        padding: 0.6rem 1.5rem;
        margin: 0;
        max-width: 1200px;
        margin-inline: auto;
    }

    .seo-copy {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem 2.5rem;
        border-top: 1px solid rgb(var(--gray-light));
    }
    .seo-copy p {
        font-size: 0.875rem;
        color: rgb(var(--gray));
        line-height: 1.6;
        margin-bottom: 0.75rem;
    }
    .seo-copy p:last-child { margin-bottom: 0; }

    .trust-section {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1.5rem 1.5rem 0;
    }
    .trust-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1.5rem;
        margin-bottom: 2rem;
    }
    .trust-badge {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.875rem;
        color: rgb(var(--gray-dark));
    }
    .badge-icon { font-size: 1rem; }

    .reviews-heading {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
    .reviews-empty {
        font-size: 0.875rem;
        color: rgb(var(--gray));
    }
    .reviews-empty a { color: inherit; }
</style>
