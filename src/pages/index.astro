---
export const prerender = false;

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { MainPage } from "../components/MainPage";
import { SITE_TITLE, SITE_DESCRIPTION, FOUNDER_PLAYING_SINCE } from "../consts";
import { fetchStoreProducts } from "../lib/stripeProducts";
import { optimizeProductImage } from "../lib/optimizeProductImage";
import type { ProductData } from "../types";
import { env } from "cloudflare:workers";
import { storeReviews, aggregateRating } from "../data/reviews";

const homeTitle = `Buy Sealed MTG Booster Boxes & Packs | ${SITE_TITLE}`;
const yearsPlaying = new Date().getFullYear() - FOUNDER_PLAYING_SINCE;

let products: ProductData[] = [];

try {
  products = await fetchStoreProducts(env);
} catch (error) {
  console.error("Failed to fetch products from Stripe:", error);
}

// A display-only copy: schema below deliberately keeps the original,
// stable `image` URL (Google prefers a canonical image URL, not a
// resized/format-shifted one) — only the on-page grid gets the optimized src.
const displayProducts: ProductData[] = await Promise.all(
  products.map(async (product) => ({
    ...product,
    imageOptimized: product.image ? await optimizeProductImage(product.image, 500) : product.image,
  }))
);

const productListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: homeTitle,
  description: SITE_DESCRIPTION,
  url: Astro.url.href,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: products.length,
    // Bare URL references only — matching the pattern already used on
    // collector-boosters.astro/play-boosters.astro. Nesting a full Product
    // here (as this previously did) is a listing-page schema misuse Google
    // flags as an invalid itemListElement and can suppress rich results
    // domain-wide; full Product/Offer markup belongs on the product page.
    itemListElement: products.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: new URL(`/product/${product.slug ?? product.id}/`, Astro.site).href,
    })),
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://simic.systems/#website",
  name: "Simic Systems",
  url: "https://simic.systems/",
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: "https://simic.systems/?q={search_term_string}",
    },
    "query-input": "required name=search_term_string",
  },
};

const reviews = storeReviews;
const rating = aggregateRating(reviews);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://simic.systems/#organization",
  name: "Simic Systems",
  legalName: "Simic Systems LLC",
  url: "https://simic.systems/",
  logo: {
    "@type": "ImageObject",
    url: "https://simic.systems/logo.png",
  },
  email: "contact@simic.systems",
  telephone: "+16055534735",
  description: "Online retailer specializing in factory-sealed Magic: The Gathering products including booster boxes and collector sets. Ships across the US.",
  areaServed: "US",
  founder: {
    "@type": "Person",
    name: "Jacob Banghart",
    jobTitle: "Founder",
  },
  ...(rating ? { aggregateRating: rating } : {}),
};

---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={homeTitle} description={SITE_DESCRIPTION} />
        <script
            type="application/ld+json"
            nonce={Astro.locals.nonce}
            set:html={JSON.stringify(productListSchema)}
        />
        <script
            type="application/ld+json"
            nonce={Astro.locals.nonce}
            set:html={JSON.stringify(websiteSchema)}
        />
        <script
            type="application/ld+json"
            nonce={Astro.locals.nonce}
            set:html={JSON.stringify(organizationSchema)}
        />
    </head>
    <body>
        <Header showCart />
        <main>
            <section class="py-16 md:py-24 bg-surface-container-lowest relative overflow-hidden border-b border-outline-variant/40">
                <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-primary-fixed-dim/5 via-surface-container-lowest to-surface-container-lowest z-0 pointer-events-none"></div>
                <div class="max-w-3xl mx-auto px-4 md:px-margin-desktop text-center relative z-10">
                    <h1 class="font-headline italic text-3xl md:text-5xl font-normal text-on-surface mb-4">
                        Sealed Magic<span class="not-italic text-primary-container">, Delivered.</span>
                    </h1>
                    <p class="font-body text-lg text-on-surface-variant/80 mb-8 mx-auto max-w-2xl">
                        Factory-sealed Magic: The Gathering play booster boxes and collector booster displays for the discerning planeswalker.
                    </p>
                    <form id="hero-search-form" class="max-w-xl mx-auto relative">
                        <input
                            id="hero-search-input"
                            class="w-full bg-surface border border-outline-variant/50 focus:border-primary-fixed-dim rounded-full py-4 pl-6 pr-12 text-on-surface font-body placeholder-on-surface-variant/50 focus:ring-1 focus:ring-primary-fixed-dim outline-none transition-all duration-300"
                            placeholder="Search for play boosters or collector displays..."
                            type="text"
                            name="q"
                        />
                        <button type="submit" class="absolute right-4 top-1/2 -translate-y-1/2 text-primary-fixed-dim hover:text-primary-container transition-colors" aria-label="Search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        </button>
                    </form>
                </div>
            </section>
            <section class="py-8 bg-surface-container-lowest border-b border-outline-variant/40">
                <div class="max-w-container-max mx-auto px-4 md:px-margin-desktop">
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 divide-x divide-outline-variant/30">
                        <div class="flex items-center justify-center gap-3 text-center px-4">
                            <svg class="text-primary-fixed-dim" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            <span class="label-caps text-on-surface/80">Secure Checkout</span>
                        </div>
                        <div class="flex items-center justify-center gap-3 text-center px-4">
                            <svg class="text-primary-fixed-dim" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="14" height="12" rx="1"/><path d="M15 10h4l3 3v5h-7z"/><circle cx="6.5" cy="19.5" r="1.75"/><circle cx="17.5" cy="19.5" r="1.75"/></svg>
                            <span class="label-caps text-on-surface/80">Ground Advantage</span>
                        </div>
                        <div class="flex items-center justify-center gap-3 text-center px-4">
                            <svg class="text-primary-fixed-dim" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.4 2.6 3.5-.5.5 3.5L21 10l-2.6 2.4.5 3.5-3.5.5L13 19l-2.4-2.6-3.5.5-.5-3.5L4 11l2.6-2.4-.5-3.5 3.5-.5z"/><path d="M9 12l2 2 4-4"/></svg>
                            <span class="label-caps text-on-surface/80">Factory Sealed</span>
                        </div>
                        <div class="flex items-center justify-center gap-3 text-center px-4">
                            <svg class="text-primary-fixed-dim" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22V3"/><path d="M4 4h13l-2.5 4L17 12H4"/></svg>
                            <span class="label-caps text-on-surface/80">US Shipping Only</span>
                        </div>
                    </div>
                </div>
            </section>
            <div id="specimens">
                <MainPage client:load products={displayProducts} />
            </div>
            <section class="trust-section">
                <div class="reviews-section">
                    <div class="reviews-header">
                        <h2 class="reviews-heading">Customer Reviews</h2>
                        {rating && (
                            <div class="reviews-summary">
                                <span class="reviews-stars" aria-label={`${rating.ratingValue} out of 5 stars`}>
                                    {[1,2,3,4,5].map(n => (
                                        <span class={n <= Math.round(Number(rating.ratingValue)) ? "star filled" : "star"}>★</span>
                                    ))}
                                </span>
                                <span class="reviews-avg">{rating.ratingValue}</span>
                                <span class="reviews-count">({rating.reviewCount} review{Number(rating.reviewCount) !== 1 ? "s" : ""})</span>
                            </div>
                        )}
                    </div>

                    {reviews.length > 0 ? (
                        <div class="reviews-grid">
                            {reviews.map(r => (
                                <article class="review-card">
                                    <div class="review-stars" aria-label={`${r.rating} out of 5`}>
                                        {[1,2,3,4,5].map(n => (
                                            <span class={n <= r.rating ? "star filled" : "star"}>★</span>
                                        ))}
                                    </div>
                                    <p class="review-text">"{r.text}"</p>
                                    <p class="review-meta">{r.author} · {r.date}</p>
                                </article>
                            ))}
                        </div>
                    ) : (
                        <p class="reviews-empty">
                            No reviews yet. Be the first.
                            <a href="https://g.page/r/simic-systems/review" rel="noopener noreferrer" class="reviews-cta">Leave a Google Review</a>
                        </p>
                    )}
                </div>
            </section>
            <section class="about-store">
                <h2 class="about-heading">About the Store</h2>
                <p>Simic Systems is an online sealed Magic: The Gathering store run by Jacob Banghart, who's been playing and collecting since {FOUNDER_PLAYING_SINCE} ({yearsPlaying} years now) and is based in North Hollywood, CA. Every product in the catalog is factory-sealed in its original manufacturer packaging: play booster boxes and collector booster displays. <a href="/about/">Learn more about Simic Systems →</a></p>
                <p>Browse by product type: <a href="/collector-boosters/">Collector Booster Displays</a> for premium foils and special treatments, or <a href="/play-boosters/">Play Booster Displays</a> for drafting and set opening.</p>
                <p>Checkout is powered by Stripe with support for Visa, Mastercard, Amex, Apple Pay, and Google Pay. All orders ship within the United States via USPS Ground Advantage. Orders over $250 require a signature upon delivery. Most orders are packed and shipped within 1–3 business days.</p>
                <p>Have a question before buying? See the <a href="/faq/">FAQ</a> for answers on payments, shipping timelines, returns, and product authenticity, or <a href="/contact/">contact us</a> directly.</p>
            </section>
        </main>
        <Footer />
        <script nonce={Astro.locals.nonce}>
        (function () {
            const form = document.getElementById('hero-search-form');
            const input = document.getElementById('hero-search-input');
            if (form && input) {
                input.addEventListener('input', function () {
                    window.dispatchEvent(new CustomEvent('site-search', { detail: input.value }));
                });
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    var query = input.value;
                    window.dispatchEvent(new CustomEvent('site-search', { detail: query }));
                    document.getElementById('specimens')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    if (query.trim()) {
                        // Result count isn't known here (filtering happens in the
                        // React product grid) — MainPage listens for this and
                        // fires the actual product_searched capture once it knows
                        // how many products matched.
                        window.dispatchEvent(new CustomEvent('site-search-submit', { detail: query.trim() }));
                    }
                });

                // Support the WebSite SearchAction (?q=...) so links generated from
                // that schema — including from search engines — actually filter results.
                const initialQuery = new URLSearchParams(window.location.search).get('q');
                if (initialQuery) {
                    input.value = initialQuery;
                    window.dispatchEvent(new CustomEvent('site-search', { detail: initialQuery }));
                    document.getElementById('specimens')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            }
        })();
        </script>
    </body>
</html>

<style>
    .about-store {
        max-width: var(--spacing-container-max);
        margin: 0 auto;
        padding: 2rem 1.5rem 2.5rem;
        border-top: 1px solid var(--color-outline-variant);
    }
    .about-heading {
        font-size: 1.1rem;
        margin-bottom: 0.75rem;
    }
    .about-store p {
        font-size: 0.925rem;
        color: rgb(var(--gray-dark) / 0.85);
        font-style: normal;
        line-height: 1.7;
        margin-bottom: 0.75rem;
    }
    .about-store p:last-child { margin-bottom: 0; }
    .about-store a { color: var(--accent); }

    .trust-section {
        max-width: var(--spacing-container-max);
        margin: 0 auto;
        padding: 1.5rem 1.5rem 0;
    }

    .reviews-section { margin-top: 1rem; }
    .reviews-header {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
        margin-bottom: 1rem;
    }
    .reviews-heading {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
    }
    .reviews-summary {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.875rem;
        color: rgb(var(--gray));
    }
    .reviews-avg { font-weight: 700; color: rgb(var(--gray-dark)); }
    .star { color: #d1d5db; font-size: 1rem; }
    .star.filled { color: #f59e0b; }

    .reviews-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1rem;
    }
    .review-card {
        border: 1px solid rgb(var(--gray-light));
        border-radius: 8px;
        padding: 1rem;
    }
    .review-stars { margin-bottom: 0.4rem; }
    .review-text {
        font-size: 0.9rem;
        line-height: 1.6;
        color: rgb(var(--gray-dark));
        margin-bottom: 0.5rem;
    }
    .review-meta {
        font-size: 0.78rem;
        color: rgb(var(--gray));
        margin: 0;
    }

    .reviews-empty {
        font-size: 0.875rem;
        color: rgb(var(--gray));
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .reviews-cta {
        display: inline-block;
        font-size: 0.8rem;
        padding: 0.3rem 0.75rem;
        border: 1px solid rgb(var(--gray-light));
        border-radius: 20px;
        color: rgb(var(--gray-dark));
        text-decoration: none;
        transition: border-color 0.15s;
    }
    .reviews-cta:hover { border-color: var(--accent); text-decoration: none; }
</style>
