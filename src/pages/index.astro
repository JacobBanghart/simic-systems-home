---
export const prerender = false;

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { MainPage } from "../components/MainPage";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { fetchStoreProducts } from "../lib/stripeProducts";
import type { ProductData } from "../types";

const { env } = Astro.locals.runtime;
const homeTitle = `Magic: The Gathering Booster Boxes | ${SITE_TITLE}`;

let products: ProductData[] = [];

try {
  products = await fetchStoreProducts(env);
} catch (error) {
  console.error("Failed to fetch products from Stripe:", error);
}

const productListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: homeTitle,
  description: SITE_DESCRIPTION,
  url: Astro.url.href,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: products.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: new URL(`/product/${product.id}/`, Astro.site).href,
      item: {
        "@type": "Product",
        name: product.name,
        description: product.description,
        image: product.image ? [product.image] : undefined,
        category: product.category,
        offers: {
          "@type": "Offer",
          priceCurrency: "USD",
          price: (product.price / 100).toFixed(2),
          availability:
            product.quantity > 0
              ? "https://schema.org/InStock"
              : "https://schema.org/OutOfStock",
          url: new URL(`/product/${product.id}/`, Astro.site).href,
        },
      },
    })),
  },
};
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={homeTitle} description={SITE_DESCRIPTION} />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(productListSchema)}
        />
    </head>
    <body>
        <Header />
        <main>
            <MainPage client:load products={products} />
        </main>
        <Footer />
    </body>
</html>
