---
export const prerender = false;

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { MainPage } from "../components/MainPage";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import Stripe from "stripe";
import type { ProductData } from "../types";

const { env } = Astro.locals.runtime;
const homeTitle = `Magic: The Gathering Booster Boxes | ${SITE_TITLE}`;

let products: ProductData[] = [];

const cached = await env.PRODUCT_CACHE.get("products", "json") as ProductData[] | null;
if (cached) {
  products = cached;
} else {
  try {
    const stripe = new Stripe(env.STRIPE_SECRET_KEY);
    const stripeProducts = await stripe.products.list({
      active: true,
      limit: 100,
      expand: ["data.default_price"],
    });

    products = stripeProducts.data
      .filter((product) => product.default_price && typeof product.default_price !== "string")
      .map((product) => {
        const price = product.default_price as Stripe.Price;
        return {
          id: product.id,
          name: product.name,
          description: product.description || "",
          category: (product.metadata.category as ProductData["category"]) || "magic",
          price: price.unit_amount || 0,
          priceId: price.id,
          quantity: parseInt(product.metadata.quantity || "0", 10),
          image: product.images[0] || "",
        };
      });

    await env.PRODUCT_CACHE.put("products", JSON.stringify(products), {
      expirationTtl: 300,
    });
  } catch (error) {
    console.error("Failed to fetch products from Stripe:", error);
  }
}

const productListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: homeTitle,
  description: SITE_DESCRIPTION,
  url: Astro.url.href,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: products.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: Astro.url.href,
      item: {
        "@type": "Product",
        name: product.name,
        description: product.description,
        image: product.image ? [product.image] : undefined,
        category: product.category,
        offers: {
          "@type": "Offer",
          priceCurrency: "USD",
          price: (product.price / 100).toFixed(2),
          availability:
            product.quantity > 0
              ? "https://schema.org/InStock"
              : "https://schema.org/OutOfStock",
          url: Astro.url.href,
        },
      },
    })),
  },
};
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={homeTitle} description={SITE_DESCRIPTION} />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(productListSchema)}
        />
    </head>
    <body>
        <Header />
        <main>
            <MainPage client:load products={products} />
        </main>
        <Footer />
    </body>
</html>
