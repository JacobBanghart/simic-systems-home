---
export const prerender = false;

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { MainPage } from "../components/MainPage";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { fetchStoreProducts } from "../lib/stripeProducts";
import type { ProductData } from "../types";
import { env } from "cloudflare:workers";
import { storeReviews, aggregateRating } from "../data/reviews";

const homeTitle = `Buy Sealed MTG Booster Boxes & Packs | ${SITE_TITLE}`;

let products: ProductData[] = [];

try {
  products = await fetchStoreProducts(env);
} catch (error) {
  console.error("Failed to fetch products from Stripe:", error);
}

const productListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: homeTitle,
  description: SITE_DESCRIPTION,
  url: Astro.url.href,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: products.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: new URL(`/product/${product.slug ?? product.id}/`, Astro.site).href,
      item: {
        "@type": "Product",
        name: product.name,
        description: product.description,
        image: product.image ? [product.image] : undefined,
        category: product.category,
        offers: {
          "@type": "Offer",
          priceCurrency: "USD",
          price: (product.price / 100).toFixed(2),
          availability:
            product.quantity > 0
              ? "https://schema.org/InStock"
              : "https://schema.org/OutOfStock",
          url: new URL(`/product/${product.slug ?? product.id}/`, Astro.site).href,
        },
      },
    })),
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Simic Systems",
  url: "https://simic.systems/",
};

const reviews = storeReviews;
const rating = aggregateRating(reviews);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://simic.systems/#organization",
  name: "Simic Systems",
  legalName: "Simic Systems LLC",
  url: "https://simic.systems/",
  logo: {
    "@type": "ImageObject",
    url: "https://simic.systems/logo.png",
  },
  email: "contact@simic.systems",
  telephone: "+16055534735",
  address: {
    "@type": "PostalAddress",
    streetAddress: "5115 Lankershim Blvd Apt 210",
    addressLocality: "North Hollywood",
    addressRegion: "CA",
    postalCode: "91601",
    addressCountry: "US",
  },
  ...(rating ? { aggregateRating: rating } : {}),
};
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={homeTitle} description={SITE_DESCRIPTION} />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(productListSchema)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(websiteSchema)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(organizationSchema)}
        />
    </head>
    <body>
        <Header showCart />
        <main>
            <img
                src="/banner.webp"
                alt="Simic Systems — Trading Card Products"
                width={1536}
                height={1024}
                fetchpriority="high"
                class="store-banner"
            />
            <h1 class="store-title">Buy Sealed Magic: The Gathering Products Online</h1>
            <MainPage client:load products={products} />
            <section class="trust-section">
                <div class="trust-badges">
                    <div class="trust-badge">
                        <span class="badge-icon">🔒</span>
                        <span>Secure checkout via Stripe</span>
                    </div>
                    <div class="trust-badge">
                        <span class="badge-icon">📦</span>
                        <span>Ships USPS Ground Advantage</span>
                    </div>
                    <div class="trust-badge">
                        <span class="badge-icon">✅</span>
                        <span>Factory-sealed product only</span>
                    </div>
                    <div class="trust-badge">
                        <span class="badge-icon">🇺🇸</span>
                        <span>US shipping only</span>
                    </div>
                </div>
                <div class="reviews-section">
                    <div class="reviews-header">
                        <h2 class="reviews-heading">Customer Reviews</h2>
                        {rating && (
                            <div class="reviews-summary">
                                <span class="reviews-stars" aria-label={`${rating.ratingValue} out of 5 stars`}>
                                    {[1,2,3,4,5].map(n => (
                                        <span class={n <= Math.round(Number(rating.ratingValue)) ? "star filled" : "star"}>★</span>
                                    ))}
                                </span>
                                <span class="reviews-avg">{rating.ratingValue}</span>
                                <span class="reviews-count">({rating.reviewCount} review{Number(rating.reviewCount) !== 1 ? "s" : ""})</span>
                            </div>
                        )}
                    </div>

                    {reviews.length > 0 ? (
                        <div class="reviews-grid">
                            {reviews.map(r => (
                                <article class="review-card">
                                    <div class="review-stars" aria-label={`${r.rating} out of 5`}>
                                        {[1,2,3,4,5].map(n => (
                                            <span class={n <= r.rating ? "star filled" : "star"}>★</span>
                                        ))}
                                    </div>
                                    <p class="review-text">"{r.text}"</p>
                                    <p class="review-meta">{r.author} · {r.date}</p>
                                </article>
                            ))}
                        </div>
                    ) : (
                        <p class="reviews-empty">
                            No reviews yet — be the first.
                            <a href="https://g.page/r/simic-systems/review" rel="noopener noreferrer" class="reviews-cta">Leave a Google Review</a>
                        </p>
                    )}
                </div>
            </section>
            <section class="about-store">
                <h2 class="about-heading">About the Store</h2>
                <p>Simic Systems is an online sealed Magic: The Gathering store run by Jacob, a lifelong MTG player based in North Hollywood, CA. Every product in the catalog is factory-sealed in its original manufacturer packaging — booster boxes, collector boxes, play boosters, draft boosters, bundles, and commander decks.</p>
                <p>Checkout is powered by Stripe with support for Visa, Mastercard, Amex, Apple Pay, and Google Pay. All orders ship within the United States via USPS Ground Advantage. Orders over $250 require a signature upon delivery. Most orders are packed and shipped within 1–3 business days.</p>
                <p>Have a question before buying? See the <a href="/faq/">FAQ</a> for answers on payments, shipping timelines, returns, and product authenticity, or <a href="/contact/">contact us</a> directly.</p>
            </section>
        </main>
        <Footer />
    </body>
</html>

<style>
    .store-banner {
        width: 100%;
        max-height: 220px;
        object-fit: cover;
        object-position: center 20%;
        display: block;
        border-radius: 0;
    }

    .store-title {
        font-size: 1rem;
        font-weight: 600;
        color: rgb(var(--gray));
        padding: 0.6rem 1.5rem;
        margin: 0;
        max-width: 1200px;
        margin-inline: auto;
    }

    .about-store {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem 2.5rem;
        border-top: 1px solid rgb(var(--gray-light));
    }
    .about-heading {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
    }
    .about-store p {
        font-size: 0.925rem;
        color: rgb(var(--gray-dark));
        line-height: 1.7;
        margin-bottom: 0.75rem;
    }
    .about-store p:last-child { margin-bottom: 0; }
    .about-store a { color: var(--accent); }

    .trust-section {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1.5rem 1.5rem 0;
    }
    .trust-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1.5rem;
        margin-bottom: 2rem;
    }
    .trust-badge {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.875rem;
        color: rgb(var(--gray-dark));
    }
    .badge-icon { font-size: 1rem; }

    .reviews-section { margin-top: 1rem; }
    .reviews-header {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
        margin-bottom: 1rem;
    }
    .reviews-heading {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
    }
    .reviews-summary {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.875rem;
        color: rgb(var(--gray));
    }
    .reviews-avg { font-weight: 700; color: rgb(var(--gray-dark)); }
    .star { color: #d1d5db; font-size: 1rem; }
    .star.filled { color: #f59e0b; }

    .reviews-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1rem;
    }
    .review-card {
        border: 1px solid rgb(var(--gray-light));
        border-radius: 8px;
        padding: 1rem;
    }
    .review-stars { margin-bottom: 0.4rem; }
    .review-text {
        font-size: 0.9rem;
        line-height: 1.6;
        color: rgb(var(--gray-dark));
        margin-bottom: 0.5rem;
    }
    .review-meta {
        font-size: 0.78rem;
        color: rgb(var(--gray));
        margin: 0;
    }

    .reviews-empty {
        font-size: 0.875rem;
        color: rgb(var(--gray));
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .reviews-cta {
        display: inline-block;
        font-size: 0.8rem;
        padding: 0.3rem 0.75rem;
        border: 1px solid rgb(var(--gray-light));
        border-radius: 20px;
        color: rgb(var(--gray-dark));
        text-decoration: none;
        transition: border-color 0.15s;
    }
    .reviews-cta:hover { border-color: var(--accent); text-decoration: none; }
</style>
