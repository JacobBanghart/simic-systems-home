---
export const prerender = false;

import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { AddToCartSection } from "../../components/AddToCartSection";
import { SITE_TITLE } from "../../consts";
import { fetchStoreProducts } from "../../lib/stripeProducts";
import { formatPrice } from "../../lib/format";

const { slug } = Astro.params;
const { env } = Astro.locals.runtime;

const products = await fetchStoreProducts(env);

// Legacy support: if the segment looks like a Stripe product ID, 301 to slug URL.
if (slug && slug.startsWith("prod_")) {
  const product = products.find((p) => p.id === slug);
  if (product?.slug) {
    return Astro.redirect(`/product/${product.slug}/`, 301);
  }
  return Astro.redirect("/404/");
}

const product = products.find((p) => p.slug === slug);

if (!product) {
  return Astro.redirect("/404/");
}

const relatedProducts = products
  .filter((p) => p.slug !== slug && p.category === product.category && p.quantity > 0)
  .slice(0, 3);

const outOfStock = product.quantity <= 0;
const categoryLabel = BRAND_NAMES[product.category] ?? product.category;

const BRAND_NAMES: Record<string, string> = {
  magic: "Magic: The Gathering",
};

// Strip trailing Stripe set name suffix e.g. " - Tarkir: Dragonstorm (TDM)"
// Uses lastIndexOf to handle hyphens within set names (e.g. "Spider-Man").
const displayName = (() => {
  const m = product.name.match(/ \([A-Z0-9]{2,5}\)\s*$/u);
  if (!m) return product.name.trim();
  const base = product.name.slice(0, m.index);
  const sep = base.lastIndexOf(' - ');
  return sep >= 0 ? base.slice(0, sep).trim() : product.name.trim();
})();

const titleName = displayName.replace(/ Booster Display$/, " Boosters").replace(/ - /, " ");
const pageTitle = `Buy ${titleName} – ${SITE_TITLE}`;
const _descCut = product.description ? product.description.lastIndexOf(' ', 153) : -1;
const pageDescription = product.description
  ? product.description.length > 157
    ? product.description.slice(0, _descCut > 0 ? _descCut : 153) + "..."
    : product.description
  : `Buy ${displayName} sealed in the US. In-stock, secure checkout, and fast shipping from Simic Systems.`;
const productUrl = new URL(`/product/${product.slug}/`, Astro.site).href;
const brandName = BRAND_NAMES[product.category] ?? product.category;

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: displayName,
  description: product.description,
  image: product.image ? [product.image] : undefined,
  category: product.category,
  sku: product.id,
  ...(product.gtin ? { gtin: product.gtin } : {}),
  brand: {
    "@type": "Brand",
    name: brandName,
  },
  offers: {
    "@type": "Offer",
    priceCurrency: "USD",
    price: (product.price / 100).toFixed(2),
    availability:
      product.quantity > 0
        ? "https://schema.org/InStock"
        : "https://schema.org/OutOfStock",
    url: productUrl,
    seller: {
      "@type": "Organization",
      name: SITE_TITLE,
      url: "https://simic.systems",
    },
    hasMerchantReturnPolicy: {
      "@type": "MerchantReturnPolicy",
      applicableCountry: "US",
      returnPolicyCategory: "https://schema.org/MerchantReturnNotPermitted",
    },
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://simic.systems/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: displayName,
      item: productUrl,
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} image={product.image} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body>
    <Header showCart />
    <main>
      <div class="product-page">

        <nav class="breadcrumb" aria-label="breadcrumb">
          <a href="/">Store</a>
          <span aria-hidden="true">›</span>
          <span>{displayName}</span>
        </nav>

        <a href="/" class="back-link">← Back to Store</a>

        <div class="product-layout">
          <div class="product-image-col">
            {product.image && (
              <img
                src={product.image}
                alt={displayName}
                width={500}
                height={500}
                loading="eager"
                fetchpriority="high"
              />
            )}
          </div>

          <div class="product-info-col">
            <span class="category-chip">{categoryLabel}</span>
            <h1>{displayName}</h1>
            <p class="product-price">{formatPrice(product.price)}</p>
            <p class={`availability${outOfStock ? " out-of-stock" : ""}`}>
              {outOfStock ? "Out of stock" : `${product.quantity} available`}
            </p>

            {product.description && (
              <p class="product-description">{product.description}</p>
            )}

            <hr class="divider" />
            <p class="shipping-info">Ships 1–3 business days · USPS · United States only</p>
            <p class="payment-info">Secure checkout · Visa · Mastercard · Amex · Apple Pay · Google Pay</p>

            <AddToCartSection client:load product={product} />
          </div>
        </div>

        {relatedProducts.length > 0 && (
          <section class="related-products">
            <h2 class="related-heading">You might also like</h2>
            <div class="related-grid">
              {relatedProducts.map((rel) => {
                const relM = rel.name.match(/ \([A-Z0-9]{2,5}\)\s*$/u);
                const relDisplayName = relM
                  ? (() => { const base = rel.name.slice(0, relM.index); const sep = base.lastIndexOf(' - '); return sep >= 0 ? base.slice(0, sep).trim() : rel.name.trim(); })()
                  : rel.name.trim();
                return (
                  <a href={`/product/${rel.slug ?? rel.id}/`} class="related-card">
                    {rel.image && (
                      <img src={rel.image} alt={relDisplayName} width={180} height={180} loading="lazy" />
                    )}
                    <p class="related-name">{relDisplayName}</p>
                    <p class="related-price">{formatPrice(rel.price)}</p>
                  </a>
                );
              })}
            </div>
          </section>
        )}

      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .product-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 1rem 1.5rem 3rem;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: rgb(var(--gray));
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .breadcrumb a {
    color: rgb(var(--gray));
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--accent); }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: rgb(var(--gray-dark));
    text-decoration: none;
    margin-bottom: 1.5rem;
  }
  .back-link:hover { color: var(--accent); text-decoration: none; }

  .product-layout {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .product-layout { flex-direction: row; align-items: flex-start; }
    .product-image-col { width: 50%; flex-shrink: 0; }
  }

  .product-image-col img {
    width: 100%;
    max-height: 500px;
    object-fit: contain;
    background: var(--bg-secondary);
    padding: 1rem;
    box-sizing: border-box;
  }

  .category-chip {
    display: inline-block;
    font-size: 0.75rem;
    padding: 0.2rem 0.75rem;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 16px;
    color: rgb(var(--gray));
    margin-bottom: 0.75rem;
  }

  .product-info-col h1 {
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .product-price {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .availability {
    font-size: 0.875rem;
    color: rgb(var(--gray));
    margin-bottom: 1rem;
  }
  .availability.out-of-stock { color: #d32f2f; }

  .product-description {
    font-size: 1rem;
    line-height: 1.7;
    color: rgb(var(--gray-dark));
    margin-bottom: 1.5rem;
  }

  .divider { margin: 1.25rem 0; }

  .shipping-info,
  .payment-info {
    font-size: 0.875rem;
    color: rgb(var(--gray));
    margin-bottom: 0.35rem;
  }

  .related-products {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .related-heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .related-grid {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    width: calc(50% - 0.5rem);
    max-width: 180px;
    text-decoration: none;
    color: rgb(var(--gray-dark));
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.15s;
  }
  .related-card:hover { border-color: var(--accent); text-decoration: none; color: rgb(var(--gray-dark)); }
  .related-card img {
    width: 100%;
    height: 120px;
    object-fit: contain;
    padding: 0.5rem;
    box-sizing: border-box;
    border-radius: 0;
  }
  .related-name {
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.3;
    padding: 0.5rem 0.5rem 0;
    margin: 0;
  }
  .related-price {
    font-size: 0.78rem;
    color: rgb(var(--gray));
    padding: 0.25rem 0.5rem 0.5rem;
    margin: 0;
  }
</style>
