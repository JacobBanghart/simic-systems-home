---
export const prerender = false;

import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { AddToCartSection } from "../../components/AddToCartSection";
import { SITE_TITLE } from "../../consts";
import { fetchStoreProducts } from "../../lib/stripeProducts";
import { optimizeProductImage } from "../../lib/optimizeProductImage";
import { formatPrice } from "../../lib/format";
import { extractProductDisplayName } from "../../lib/productDisplay";
import { env } from "cloudflare:workers";
import { productReviews, aggregateRating } from "../../data/reviews";

const { slug } = Astro.params;

const products = await fetchStoreProducts(env);

// Legacy support: if the segment looks like a Stripe product ID, 301 to slug URL.
if (slug && slug.startsWith("prod_")) {
  const product = products.find((p) => p.id === slug);
  if (product?.slug) {
    return Astro.redirect(`/product/${product.slug}/`, 301);
  }
  // Rewrite (not redirect) so unknown product URLs return a real 404 status
  // instead of a 302 to a page that responds 200 — see src/pages/404.astro.
  return Astro.rewrite("/404");
}

const product = products.find((p) => p.slug === slug);

if (!product) {
  return Astro.rewrite("/404");
}

// Extract set name as the portion before the first " - " (e.g. "Tarkir: Dragonstorm")
const getSetName = (name: string) => {
  const sep = name.indexOf(" - ");
  return sep >= 0 ? name.slice(0, sep).trim() : name.trim();
};
const productSetName = getSetName(product.name);

// Prefer same-set (different product type), then same-category, capped at 3
const sameSet = products.filter(
  (p) => p.slug !== slug && p.quantity > 0 && getSetName(p.name) === productSetName
);
const sameCategory = products.filter(
  (p) => p.slug !== slug && p.quantity > 0 && p.category === product.category && getSetName(p.name) !== productSetName
);
const relatedProducts = [...sameSet, ...sameCategory].slice(0, 3);

// Display-only optimized renditions — schema below keeps product.image /
// rel.image (the original, stable URL) unchanged for structured data.
const productImageOptimized = product.image
  ? await optimizeProductImage(product.image, 700, env.PRODUCT_CACHE)
  : product.image;
const relatedImagesOptimized = await Promise.all(
  relatedProducts.map((rel) =>
    rel.image ? optimizeProductImage(rel.image, 250, env.PRODUCT_CACHE) : rel.image
  )
);

const BRAND_NAMES: Record<string, string> = {
  magic: "Magic: The Gathering",
};

const outOfStock = product.quantity <= 0;
const lowStock = !outOfStock && product.quantity <= 3;
// Precomputed rather than inline in the template below — the astro template
// parser misreads a `<=` comparison as the leading token of a ternary's
// false-branch as the start of a tag, throwing a bogus "Fragment shorthand
// syntax" parse error (astro-eslint-parser 2.1.0). Plain frontmatter script
// isn't affected, only the JSX-aware scanner is.
const availabilityClass = outOfStock ? " out-of-stock" : lowStock ? " low-stock" : "";
const availabilityText = outOfStock
  ? "Out of stock"
  : lowStock
  ? `Only ${product.quantity} left — order soon`
  : `${product.quantity} available`;
const categoryLabel = BRAND_NAMES[product.category] ?? product.category;
const reviews = productReviews[product.slug ?? ""] ?? [];
const rating = aggregateRating(reviews);

// Structural pack facts, not per-set claims (format legality varies by set
// and isn't safe to state generically — see product description for that).
// Numbers match the comparison table on /collector-boosters/ and /play-boosters/.
// Play Booster Displays are 30 packs except Foundations, which ships 36.
// Jumpstart Boosters are a distinct 24-pack/20-card format grouped under the
// /play-boosters/ category page alongside regular Play Boosters.
const nameLower = product.name.toLowerCase();
const isCollectorBooster = nameLower.includes("collector booster");
const isJumpstart = nameLower.includes("jumpstart booster");
const isPlayBoosterFormat = nameLower.includes("play booster");
const isFoundations = nameLower.includes("foundations");
const isPlayBoosterCategory = isPlayBoosterFormat || isJumpstart;

const productSpecs = isCollectorBooster
  ? {
      label: "Collector Booster Display",
      packs: 12,
      cardsPerPack: 15,
      totalCards: 180,
      rareGuarantee: "5+ rares or mythic rares guaranteed per pack",
      foilGuarantee: "Multiple foils guaranteed in every pack",
    }
  : isJumpstart
  ? {
      label: "Jumpstart Booster Display",
      packs: 24,
      cardsPerPack: 20,
      totalCards: 480,
      rareGuarantee: "No deck-building needed — pick 2 themed boosters, shuffle, and play",
      foilGuarantee: "Bonus themed foil/land card in every pack",
    }
  : isPlayBoosterFormat && isFoundations
  ? {
      label: "Play Booster Display",
      packs: 36,
      cardsPerPack: 14,
      totalCards: 504,
      rareGuarantee: "1 rare or mythic rare guaranteed per pack",
      foilGuarantee: "At least 1 traditional foil per pack",
    }
  : isPlayBoosterFormat
  ? {
      label: "Play Booster Display",
      packs: 30,
      cardsPerPack: 14,
      totalCards: 420,
      rareGuarantee: "1 rare or mythic rare guaranteed per pack",
      foilGuarantee: "At least 1 traditional foil per pack",
    }
  : null;

const displayName = extractProductDisplayName(product.name);

const titleName = displayName.replace(/ Booster Display$/, " Boosters").replace(/ - /, " ");
const pageTitle = `Buy ${titleName} – ${SITE_TITLE}`;
const _descCut = product.description ? product.description.lastIndexOf(' ', 153) : -1;
const pageDescription = product.description
  ? product.description.length > 157
    ? product.description.slice(0, _descCut > 0 ? _descCut : 153) + "..."
    : product.description
  : `Buy ${displayName} sealed in the US. In-stock, secure checkout, and fast shipping from Simic Systems.`;
const productUrl = new URL(`/product/${product.slug}/`, Astro.site).href;
const brandName = BRAND_NAMES[product.category] ?? product.category;

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: displayName,
  description: product.description,
  image: product.image ? [product.image] : undefined,
  category: product.category,
  sku: product.id,
  ...(product.gtin ? { gtin: product.gtin } : {}),
  brand: {
    "@type": "Brand",
    name: brandName,
  },
  ...(rating ? { aggregateRating: rating } : {}),
  offers: {
    "@type": "Offer",
    priceCurrency: "USD",
    price: (product.price / 100).toFixed(2),
    availability:
      product.quantity > 0
        ? "https://schema.org/InStock"
        : "https://schema.org/OutOfStock",
    itemCondition: "https://schema.org/NewCondition",
    url: productUrl,
    seller: {
      "@type": "Organization",
      name: SITE_TITLE,
      url: "https://simic.systems",
    },
    hasMerchantReturnPolicy: {
      "@type": "MerchantReturnPolicy",
      applicableCountry: "US",
      returnPolicyCategory: "https://schema.org/MerchantReturnNotPermitted",
    },
    shippingDetails: {
      "@type": "OfferShippingDetails",
      shippingRate: {
        "@type": "MonetaryAmount",
        currency: "USD",
        value: "0",
      },
      shippingDestination: {
        "@type": "DefinedRegion",
        addressCountry: "US",
      },
      deliveryTime: {
        "@type": "ShippingDeliveryTime",
        handlingTime: {
          "@type": "QuantitativeValue",
          minValue: 1,
          maxValue: 3,
          unitCode: "DAY",
        },
        transitTime: {
          "@type": "QuantitativeValue",
          minValue: 3,
          maxValue: 7,
          unitCode: "DAY",
        },
      },
    },
  },
};

const categoryCrumb = isCollectorBooster
  ? { name: "Collector Boosters", href: "/collector-boosters/" }
  : isPlayBoosterCategory
  ? { name: "Play Boosters", href: "/play-boosters/" }
  : null;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://simic.systems/",
    },
    ...(categoryCrumb
      ? [
          {
            "@type": "ListItem",
            position: 2,
            name: categoryCrumb.name,
            item: new URL(categoryCrumb.href, Astro.site).href,
          },
        ]
      : []),
    {
      "@type": "ListItem",
      position: categoryCrumb ? 3 : 2,
      name: displayName,
      item: productUrl,
    },
  ],
};

const nonce = Astro.locals.nonce;

// Vars are inlined via a template literal (JSON.stringify'd) instead of
// define:vars — the Astro compiler silently drops any other dynamic
// attribute (including nonce={...}) from a <script> tag that also uses
// define:vars.
const productViewedScript = `(function(){
var productSlug = ${JSON.stringify(product.slug ?? "")};
var productName = ${JSON.stringify(product.name)};
var productPrice = ${JSON.stringify(product.price)};
var productCategory = ${JSON.stringify(product.category)};
var productOutOfStock = ${JSON.stringify(outOfStock)};
window.addEventListener('load', function () {
  try {
    window.posthog?.capture('product_viewed', {
      product_slug: productSlug,
      product_name: productName,
      price_cents: productPrice,
      category: productCategory,
      out_of_stock: productOutOfStock,
    });
  } catch (err) {
    window.posthog?.captureException(err);
  }
});
})();`;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} image={product.image} ogType="product" robots={product.noindex ? "noindex, nofollow" : undefined} />
    <script type="application/ld+json" nonce={nonce} set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" nonce={nonce} set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body>
    <Header showCart />
    <main>
      <div class="product-page">

        <nav class="breadcrumb" aria-label="breadcrumb">
          <a href="/">Store</a>
          {categoryCrumb && (
            <>
              <span aria-hidden="true">›</span>
              <a href={categoryCrumb.href}>{categoryCrumb.name}</a>
            </>
          )}
          <span aria-hidden="true">›</span>
          <span>{displayName}</span>
        </nav>

        <a href="/" class="back-link">← Back to Store</a>

        <div class="product-layout">
          <div class="product-image-col">
            {product.image && (
              <img
                src={productImageOptimized}
                alt={displayName}
                width={500}
                height={500}
                loading="eager"
                fetchpriority="high"
              />
            )}
          </div>

          <div class="product-info-col">
            <span class="category-chip">{categoryLabel}</span>
            <h1>{displayName}</h1>
            <p class="product-price">{formatPrice(product.price)}</p>
            <p class={`availability${availabilityClass}`}>
              {availabilityText}
            </p>

            <AddToCartSection client:load product={product} />

            <p class="shipping-info">Ships 1–3 business days · <a href="/shipping/">USPS Ground Advantage</a> · United States only</p>
            <p class="payment-info">Secure checkout · Visa · Mastercard · Amex · Apple Pay · Google Pay · <a href="/faq/">FAQ</a></p>
            <p class="returns-info">Sealed product only — once a box ships, its seal integrity can't be re-verified, so all sales are final. Arrives damaged or wrong? <a href="/contact/">Contact us</a> within 7 days and we'll make it right.</p>

            <hr class="divider" />

            {productSpecs && (
              <dl class="product-specs">
                <div><dt>Format</dt><dd>{productSpecs.label}</dd></div>
                <div><dt>Packs per display</dt><dd>{productSpecs.packs}</dd></div>
                <div><dt>Cards per pack</dt><dd>{productSpecs.cardsPerPack}</dd></div>
                <div><dt>Total cards</dt><dd>{productSpecs.totalCards}</dd></div>
                <div><dt>Rare/mythic guarantee</dt><dd>{productSpecs.rareGuarantee}</dd></div>
                <div><dt>Foil guarantee</dt><dd>{productSpecs.foilGuarantee}</dd></div>
              </dl>
            )}

            {product.description && (
              <p class="product-description">{product.description}</p>
            )}
          </div>
        </div>

        <section class="product-reviews">
          <div class="product-reviews-header">
            <h2 class="product-reviews-heading">Customer Reviews</h2>
            {rating && (
              <div class="reviews-summary">
                <span aria-label={`${rating.ratingValue} out of 5 stars`}>
                  {[1,2,3,4,5].map(n => (
                    <span class={n <= Math.round(Number(rating.ratingValue)) ? "star filled" : "star"}>★</span>
                  ))}
                </span>
                <span class="reviews-avg">{rating.ratingValue}</span>
                <span class="reviews-count">({rating.reviewCount} review{Number(rating.reviewCount) !== 1 ? "s" : ""})</span>
              </div>
            )}
          </div>
          {reviews.length > 0 ? (
            <div class="reviews-grid">
              {reviews.map(r => (
                <article class="review-card">
                  <div class="review-stars" aria-label={`${r.rating} out of 5`}>
                    {[1,2,3,4,5].map(n => (
                      <span class={n <= r.rating ? "star filled" : "star"}>★</span>
                    ))}
                  </div>
                  <p class="review-text">"{r.text}"</p>
                  <p class="review-meta">{r.author} · {r.date}</p>
                </article>
              ))}
            </div>
          ) : (
            <p class="reviews-empty">
              No reviews yet — be the first.
              <a href="https://g.page/r/simic-systems/review" rel="noopener noreferrer" class="reviews-cta">Leave a Google Review</a>
            </p>
          )}
        </section>

        {relatedProducts.length > 0 && (
          <section class="related-products">
            <h2 class="related-heading">You might also like</h2>
            <div class="related-grid">
              {relatedProducts.map((rel, relIndex) => {
                const relDisplayName = extractProductDisplayName(rel.name);
                return (
                  <a href={`/product/${rel.slug ?? rel.id}/`} class="related-card">
                    {rel.image && (
                      <img src={relatedImagesOptimized[relIndex]} alt={relDisplayName} width={180} height={180} loading="lazy" />
                    )}
                    <p class="related-name">{relDisplayName}</p>
                    <p class="related-price">{formatPrice(rel.price)}</p>
                  </a>
                );
              })}
            </div>
          </section>
        )}

      </div>
    </main>
    <Footer />
  </body>
</html>

<script is:inline nonce={nonce} set:html={productViewedScript} />

<style>
  .product-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 1rem 1.5rem 3rem;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: rgb(var(--gray));
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .breadcrumb a {
    color: rgb(var(--gray));
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--accent); }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: rgb(var(--gray-dark));
    text-decoration: none;
    margin-bottom: 1.5rem;
  }
  .back-link:hover { color: var(--accent); text-decoration: none; }

  .product-layout {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .product-layout { flex-direction: row; align-items: flex-start; }
    .product-image-col { width: 50%; flex-shrink: 0; }
  }

  .product-image-col img {
    width: 100%;
    max-height: 500px;
    object-fit: contain;
    background: var(--md-surface-container-low);
    border: 1px solid var(--color-outline-variant);
    border-radius: 4px;
    padding: 2rem 1rem 1rem;
    box-sizing: border-box;
  }

  .category-chip {
    display: inline-block;
    font-size: 0.75rem;
    padding: 0.2rem 0.75rem;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 16px;
    color: rgb(var(--gray));
    margin-bottom: 0.75rem;
  }

  .product-info-col h1 {
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .product-price {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .availability {
    font-size: 0.875rem;
    color: rgb(var(--gray));
    margin-bottom: 1rem;
  }
  /* #ff6659 rather than the more common Material red #d32f2f — against this
     theme's dark background (#0d1513) #d32f2f computes to ~3.72:1 contrast,
     below WCAG AA's 4.5:1 minimum for normal text; #ff6659 clears ~6.4:1. */
  .availability.out-of-stock { color: #ff6659; }
  .availability.low-stock { color: #e65100; font-weight: 600; }

  .product-description {
    font-size: 1rem;
    line-height: 1.7;
    color: rgb(var(--gray-dark));
    margin-bottom: 1.5rem;
  }

  .product-specs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.6rem 1.5rem;
    margin: 0 0 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--md-surface-container-low);
    border: 1px solid var(--color-outline-variant);
    border-radius: 8px;
  }
  .product-specs div {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    font-size: 0.85rem;
  }
  .product-specs dt {
    color: rgb(var(--gray));
  }
  .product-specs dd {
    margin: 0;
    font-weight: 600;
    color: rgb(var(--gray-dark));
    text-align: right;
  }
  @media (max-width: 480px) {
    .product-specs { grid-template-columns: 1fr; }
  }

  .divider { margin: 1.25rem 0; }

  .shipping-info,
  .payment-info,
  .returns-info {
    font-size: 0.875rem;
    color: rgb(var(--gray));
    margin-bottom: 0.35rem;
  }

  .related-products {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .related-heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .related-grid {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    width: calc(50% - 0.5rem);
    max-width: 180px;
    text-decoration: none;
    color: rgb(var(--gray-dark));
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.15s;
  }
  .related-card:hover { border-color: var(--accent); text-decoration: none; color: rgb(var(--gray-dark)); }
  .related-card img {
    width: 100%;
    height: 120px;
    object-fit: contain;
    background: var(--md-surface-container-low);
    padding: 0.75rem 0.5rem 0.5rem;
    box-sizing: border-box;
    border-radius: 0;
  }
  .related-name {
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.3;
    padding: 0.5rem 0.5rem 0;
    margin: 0;
  }
  .related-price {
    font-size: 0.78rem;
    color: rgb(var(--gray));
    padding: 0.25rem 0.5rem 0.5rem;
    margin: 0;
  }

  .product-reviews {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .product-reviews-header {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin-bottom: 1rem;
  }
  .product-reviews-heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }
  .reviews-summary {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    color: rgb(var(--gray));
  }
  .reviews-avg { font-weight: 700; color: rgb(var(--gray-dark)); }
  .star { color: #d1d5db; }
  .star.filled { color: #f59e0b; }
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .review-card {
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
    padding: 1rem;
  }
  .review-stars { margin-bottom: 0.4rem; }
  .review-text {
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgb(var(--gray-dark));
    margin-bottom: 0.5rem;
  }
  .review-meta { font-size: 0.78rem; color: rgb(var(--gray)); margin: 0; }
  .reviews-empty {
    font-size: 0.875rem;
    color: rgb(var(--gray));
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin: 0;
  }
  .reviews-cta {
    display: inline-block;
    font-size: 0.8rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 20px;
    color: rgb(var(--gray-dark));
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .reviews-cta:hover { border-color: var(--accent); }
</style>
