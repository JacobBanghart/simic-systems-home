---
export const prerender = false;

import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { ProductDetail } from "../../components/ProductDetail";
import { SITE_TITLE } from "../../consts";
import { fetchStoreProducts } from "../../lib/stripeProducts";

const { id } = Astro.params;
const { env } = Astro.locals.runtime;

let products = await fetchStoreProducts(env);
const product = products.find((p) => p.id === id);

if (!product) {
  return Astro.redirect("/404/");
}

const BRAND_NAMES: Record<string, string> = {
  magic: "Magic: The Gathering",
};

const pageTitle = `${product.name} | ${SITE_TITLE}`;
const pageDescription = product.description || `Buy ${product.name} at ${SITE_TITLE}`;
const productUrl = new URL(`/product/${product.id}/`, Astro.site).href;
const brandName = BRAND_NAMES[product.category] ?? product.category;

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  description: product.description,
  image: product.image ? [product.image] : undefined,
  category: product.category,
  sku: product.id,
  ...(product.gtin ? { gtin: product.gtin } : {}),
  brand: {
    "@type": "Brand",
    name: brandName,
  },
  offers: {
    "@type": "Offer",
    priceCurrency: "USD",
    price: (product.price / 100).toFixed(2),
    availability:
      product.quantity > 0
        ? "https://schema.org/InStock"
        : "https://schema.org/OutOfStock",
    url: productUrl,
    seller: {
      "@type": "Organization",
      name: SITE_TITLE,
      url: "https://simic.systems",
    },
    hasMerchantReturnPolicy: {
      "@type": "MerchantReturnPolicy",
      applicableCountry: "US",
      returnPolicyCategory: "https://schema.org/MerchantReturnNotPermitted",
    },
    shippingDetails: {
      "@type": "OfferShippingDetails",
      shippingRate: {
        "@type": "MonetaryAmount",
        currency: "USD",
      },
      shippingDestination: {
        "@type": "DefinedRegion",
        addressCountry: "US",
      },
      deliveryTime: {
        "@type": "ShippingDeliveryTime",
        businessDays: {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: [
            "https://schema.org/Monday",
            "https://schema.org/Tuesday",
            "https://schema.org/Wednesday",
            "https://schema.org/Thursday",
            "https://schema.org/Friday",
          ],
        },
        transitTime: {
          "@type": "QuantitativeValue",
          minValue: 3,
          maxValue: 7,
          unitCode: "DAY",
        },
      },
    },
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://simic.systems/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: product.name,
      item: productUrl,
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} image={product.image} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body>
    <Header showCart />
    <main>
      <ProductDetail client:load product={product} />
    </main>
    <Footer />
  </body>
</html>
