---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const faqs = [
	{
		question: "What payment methods do you accept?",
		answer: "We accept Visa, Mastercard, American Express, Apple Pay, and Google Pay. All payments are processed securely through Stripe.",
	},
	{
		question: "Do you ship internationally?",
		answer: "We currently ship within the United States only via USPS. See our <a href=\"/shipping/\">Shipping & Returns</a> page for full details.",
		schemaAnswer: "We currently ship within the United States only via USPS. See our Shipping & Returns page for full details.",
	},
	{
		question: "How long does shipping take?",
		answer: "Orders are typically processed within a few business days, with delivery via USPS after that. See our <a href=\"/shipping/\">Shipping & Returns</a> page for current timeframes.",
		schemaAnswer: "Orders are typically processed within a few business days, with delivery via USPS after that. See our Shipping & Returns page for current timeframes.",
	},
	{
		question: "What is your return policy?",
		answer: "We accept returns of unopened, factory-sealed items within a limited window after delivery. See our <a href=\"/shipping/\">Shipping & Returns</a> page for the full policy.",
		schemaAnswer: "We accept returns of unopened, factory-sealed items within a limited window after delivery. See our Shipping & Returns page for the full policy.",
	},
	{
		question: "Are all products sealed and authentic?",
		answer: "Yes. All products are factory-sealed and sourced from authorized distributors. We never sell repackaged or tampered products.",
	},
	{
		question: "How do I track my order?",
		answer: "You'll receive a shipping confirmation email with a USPS tracking number once your order has shipped.",
	},
	{
		question: "What if my order arrives damaged?",
		answer: "Please <a href=\"/contact/\">contact us</a> within 7 days of delivery with photos of the issue and your order number, and we'll make it right.",
		schemaAnswer: "Please contact us within 7 days of delivery with photos of the issue and your order number, and we'll make it right.",
	},
	{
		question: "Do you offer bulk or wholesale pricing?",
		answer: "We don't currently offer bulk pricing through the website. If you're interested in a larger order, please <a href=\"/contact/\">contact us</a> and we can discuss options.",
		schemaAnswer: "We don't currently offer bulk pricing through the website. If you're interested in a larger order, please contact us and we can discuss options.",
	}
];

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: faqs.map((faq) => ({
		"@type": "Question",
		name: faq.question,
		acceptedAnswer: {
			"@type": "Answer",
			text: faq.schemaAnswer || faq.answer,
		},
	})),
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`FAQ - ${SITE_TITLE}`} description="Frequently asked questions about Simic Systems — shipping, returns, payment methods, and more." />
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<h1>Frequently Asked Questions</h1>
				<div class="faq-list">
					{faqs.map((faq) => (
						<details class="faq-item">
							<summary>{faq.question}</summary>
							<p set:html={faq.answer} />
						</details>
					))}
				</div>
				<p class="cta">
					Still have questions? <a href="/contact/">Contact us</a> and we'll be happy to help.
				</p>
			</article>
		</main>
		<Footer />
	</body>
</html>
<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 1rem 1.5rem;
	}
	article h1 {
		margin-bottom: 1.5rem;
	}
	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.faq-item {
		border: 1px solid rgba(var(--gray-light), 0.4);
		border-radius: 6px;
		overflow: hidden;
	}
	.faq-item summary {
		padding: 1rem 1.25rem;
		cursor: pointer;
		font-weight: 600;
		font-size: 1rem;
		list-style: none;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.faq-item summary::after {
		content: "+";
		font-size: 1.2rem;
		font-weight: 400;
		flex-shrink: 0;
		margin-left: 1rem;
	}
	.faq-item[open] summary::after {
		content: "−";
	}
	.faq-item summary::-webkit-details-marker {
		display: none;
	}
	.faq-item p {
		padding: 0 1.25rem 1rem;
		margin: 0;
		line-height: 1.6;
		color: rgb(var(--gray));
	}
	.cta {
		margin-top: 2rem;
		text-align: center;
	}
</style>
