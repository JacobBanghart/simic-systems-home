---
import BaseHead from "../../components/BaseHead.astro";
import { SITE_TITLE } from "../../consts";
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`Order Confirmed - ${SITE_TITLE}`} description="Thank you for your purchase" />
        <meta name="robots" content="noindex, nofollow" />
    </head>
    <body>
        <main style="max-width: 600px; margin: 0 auto; padding: 2rem; text-align: center;">
            <h1>Thank you for your order!</h1>
            <p>Your payment was successful. We'll ship your items soon.</p>
            <p>You'll receive a confirmation email from Stripe with your receipt.</p>
            <a href="/" style="display: inline-block; margin-top: 1rem; padding: 0.75rem 1.5rem; background: #279214; color: white; text-decoration: none; border-radius: 4px;">
                Back to Store
            </a>
        </main>
        <script>
            localStorage.removeItem("simic-cart");
        </script>
    </body>
</html>
