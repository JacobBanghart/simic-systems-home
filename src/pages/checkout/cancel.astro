---
import BaseHead from "../../components/BaseHead.astro";
import { SITE_TITLE } from "../../consts";
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`Order Cancelled - ${SITE_TITLE}`} description="Your order was cancelled" />
        <meta name="robots" content="noindex, nofollow" />
    </head>
    <body>
        <main style="max-width: 600px; margin: 0 auto; padding: 2rem; text-align: center;">
            <h1>Order Cancelled</h1>
            <p>Your order was cancelled and you have not been charged.</p>
            <a href="/" style="display: inline-block; margin-top: 1rem; padding: 0.75rem 1.5rem; background: #279214; color: white; text-decoration: none; border-radius: 4px;">
                Back to Store
            </a>
        </main>
    </body>
</html>
