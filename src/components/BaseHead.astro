---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../styles/global.css";
import PostHog from "./posthog.astro";

interface Props {
	title: string;
	description: string;
	image?: string;
	ogType?: string;
	robots?: string;
}

const { title, description, image = "/banner.webp", ogType = "website", robots = "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
---

<!-- Set background inline, synchronously before any stylesheet loads, to prevent a white flash. -->
<script is:inline nonce={Astro.locals.nonce}>
document.documentElement.style.backgroundColor = '#08100e';
</script>

<!-- Fonts: loaded non-render-blocking (media="print" swapped to "all" once
     fetched) since the CSP here is nonce-based and doesn't cover inline
     onload="" attributes — the swap has to happen from a nonce'd <script>. -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	id="google-fonts-css"
	href="https://fonts.googleapis.com/css2?family=Libre+Caslon+Text:ital,wght@0,400;0,700;1,400&family=Hanken+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
	rel="stylesheet"
	media="print"
/>
<script is:inline nonce={Astro.locals.nonce}>
(function () {
	var link = document.getElementById('google-fonts-css');
	if (!link) return;
	if (link.sheet) { link.media = 'all'; return; }
	link.addEventListener('load', function () { link.media = 'all'; }, { once: true });
})();
</script>
<noscript>
	<link
		href="https://fonts.googleapis.com/css2?family=Libre+Caslon+Text:ital,wght@0,400;0,700;1,400&family=Hanken+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
		rel="stylesheet"
	/>
</noscript>

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="robots" content={robots} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageURL} />

<!-- Ahrefs Analytics -->
<link rel="preconnect" href="https://analytics.ahrefs.com" />
<script src="https://analytics.ahrefs.com/analytics.js" data-key="HH7C5fKtdzEVU5dAN9p53A" async></script>

<PostHog />
