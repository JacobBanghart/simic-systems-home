---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="footer-links">
			<a href="/about/">About</a>
			<a href="/contact/">Contact</a>
			<a href="/faq/">FAQ</a>
			<a href="/shipping/">Shipping Policy</a>
			<a href="/privacy/">Privacy Policy</a>
			<a href="/terms/">Terms of Service</a>
		</div>
		<p class="nap">5115 Lankershim Blvd Apt 210, North Hollywood, CA 91601 &middot; <a href="tel:+16055534735">(605) 553-4735</a></p>
		<p>&copy; {today.getFullYear()} Simic Systems. All rights reserved.</p>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 3em 1em;
		background: var(--bg-secondary);
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-content {
		max-width: 720px;
		margin: 0 auto;
	}
	.footer-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1em 1.5em;
		margin-bottom: 1em;
	}
	.footer-links a {
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.9em;
	}
	.footer-links a:hover {
		color: rgb(var(--gray-dark));
		text-decoration: underline;
	}
	.nap {
		font-size: 0.8em;
		margin: 0 0 0.5em 0;
		opacity: 0.7;
	}
	.nap a {
		color: inherit;
		text-decoration: none;
	}
	.nap a:hover {
		text-decoration: underline;
	}
	p {
		font-size: 0.85em;
		margin: 0;
	}
</style>
