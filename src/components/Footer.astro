---
const today = new Date();
---

<footer class="bg-surface-container-lowest pt-16 pb-8 border-t border-outline-variant/40">
	<div class="max-w-container-max mx-auto px-4 md:px-margin-desktop grid grid-cols-1 md:grid-cols-12 gap-10 mb-12">
		<div class="md:col-span-6 lg:col-span-4">
			<div class="font-headline italic text-lg text-on-surface mb-3">Simic Systems</div>
			<p class="font-body text-sm text-on-surface-variant/70 font-light mb-5 max-w-sm">
				Factory-sealed Magic: The Gathering play booster boxes and collector booster displays, sourced and shipped from North Hollywood, CA.
			</p>
			<div class="label-caps text-on-surface/60 leading-relaxed">
				North Hollywood, CA<br />
				<a href="tel:+16055534735" class="hover:text-on-surface transition-colors">(605) 553-4735</a>
			</div>
		</div>
		<div class="md:col-span-3 lg:col-span-2 lg:col-start-7">
			<h2 class="label-caps text-primary-fixed-dim mb-5 tracking-[0.2em]">Resources</h2>
			<ul class="space-y-3 font-body font-light text-on-surface-variant/70 text-sm list-none p-0 m-0">
				<li><a class="hover:text-on-surface transition-colors" href="/faq/">FAQ</a></li>
				<li><a class="hover:text-on-surface transition-colors" href="/contact/">Contact</a></li>
				<li><a class="hover:text-on-surface transition-colors" href="/shipping/">Shipping</a></li>
				<li><a class="hover:text-on-surface transition-colors" href="/collector-boosters/">Collector Boosters</a></li>
				<li><a class="hover:text-on-surface transition-colors" href="/play-boosters/">Play Boosters</a></li>
			</ul>
		</div>
		<div class="md:col-span-3 lg:col-span-2">
			<h2 class="label-caps text-primary-fixed-dim mb-5 tracking-[0.2em]">Legal</h2>
			<ul class="space-y-3 font-body font-light text-on-surface-variant/70 text-sm list-none p-0 m-0">
				<li><a class="hover:text-on-surface transition-colors" href="/about/">About</a></li>
				<li><a class="hover:text-on-surface transition-colors" href="/privacy/">Privacy Policy</a></li>
				<li><a class="hover:text-on-surface transition-colors" href="/terms/">Terms of Service</a></li>
			</ul>
		</div>
	</div>
	<div class="max-w-container-max mx-auto px-4 md:px-margin-desktop border-t border-outline-variant/40 pt-6 text-center flex flex-col md:flex-row justify-between items-center gap-3">
		<p class="label-caps text-on-surface/60 m-0">&copy; {today.getFullYear()} Simic Systems. All rights reserved.</p>
		<p class="label-caps text-on-surface/60 m-0">Secured by Stripe</p>
	</div>
</footer>
