---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	showCart?: boolean;
}

const { showCart = false } = Astro.props;
---

<header class="sticky top-0 z-50 bg-surface-container-lowest/90 backdrop-blur-md border-b border-outline-variant/40">
	<nav class="flex items-center px-4 md:px-margin-desktop py-4 max-w-container-max mx-auto">
		<h2 class="m-0 text-lg font-headline italic font-normal">
			<a href="/" class="no-underline text-on-surface">{SITE_TITLE}</a>
		</h2>
		<div class="internal-links flex items-center ml-auto gap-1 md:gap-8">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/about/">About</HeaderLink>
			<HeaderLink href="/faq/">FAQ</HeaderLink>
			<HeaderLink href="/contact/">Contact</HeaderLink>
		</div>
		<div id="cart-button-portal" class="flex items-center">
			{showCart && (
				<button type="button" class="cart-placeholder flex items-center justify-center p-2 text-on-surface/70" aria-label="Shopping cart" disabled>
					<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2m10 0c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2m-8.9-5h7.45c.75 0 1.41-.41 1.75-1.03L21 4.96 19.25 4l-3.7 7H8.53L4.27 2H1v2h2l3.6 7.59-1.35 2.44C4.52 15.37 5.48 17 7 17h12v-2H7zM12 2l4 4-4 4-1.41-1.41L12.17 7H8V5h4.17l-1.59-1.59z"/></svg>
				</button>
			)}
		</div>
		<button id="menu-toggle" type="button" aria-label="Toggle menu" class="menu-toggle flex items-center justify-center p-2 text-on-surface">
			<svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
			<svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
		</button>
	</nav>
</header>

<script is:inline nonce={Astro.locals.nonce}>
(function() {
	const menuBtn = document.getElementById('menu-toggle');
	const nav = document.querySelector('header nav');
	if (menuBtn && nav) {
		menuBtn.addEventListener('click', function() {
			nav.classList.toggle('open');
		});
	}

})();
</script>

<style>
	.internal-links :global(a) {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.6em 0.5em;
		color: rgb(var(--gray-dark) / 0.7);
		border-bottom: 2px solid transparent;
		text-decoration: none;
		transition: color 0.2s;
	}
	.internal-links :global(a:hover) {
		color: var(--color-primary-fixed-dim);
		text-decoration: none;
	}
	.internal-links :global(a.active) {
		text-decoration: none;
		color: rgb(var(--gray-dark));
		border-bottom-color: var(--color-primary-fixed-dim);
	}

	#cart-button-portal :global(.MuiIconButton-root) {
		background: transparent;
		color: rgb(var(--gray-dark) / 0.7) !important;
		border-radius: 8px;
		padding: 6px;
		min-width: 48px;
		min-height: 48px;
		transition: color 0.2s;
	}
	#cart-button-portal :global(.MuiIconButton-root:hover) {
		color: var(--color-primary-fixed-dim) !important;
	}
	.cart-placeholder {
		background: transparent;
		border: none;
		cursor: default;
		min-width: 48px;
		min-height: 48px;
	}

	/* Hamburger menu button — hidden on desktop */
	.menu-toggle {
		display: none;
		min-width: 48px;
		min-height: 48px;
	}
	.menu-toggle .icon-close {
		display: none;
	}
	nav.open .menu-toggle .icon-menu {
		display: none;
	}
	nav.open .menu-toggle .icon-close {
		display: block;
	}

	/* Mobile: collapse nav into hamburger */
	@media (max-width: 600px) {
		nav {
			flex-wrap: wrap;
		}
		.menu-toggle {
			display: flex;
		}
		.internal-links {
			display: none;
			width: 100%;
			flex-direction: column;
			align-items: stretch;
			border-top: 1px solid var(--color-outline-variant);
			order: 99;
			margin-left: 0;
		}
		nav.open .internal-links {
			display: flex;
		}
		.internal-links :global(a) {
			padding: 0.75em 0;
			border-bottom: none;
		}
		#cart-button-portal {
			margin-left: auto;
		}
	}
</style>
