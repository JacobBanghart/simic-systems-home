---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	showCart?: boolean;
}

const { showCart = false } = Astro.props;
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/about/">About</HeaderLink>
			<HeaderLink href="/faq/">FAQ</HeaderLink>
			<HeaderLink href="/contact/">Contact</HeaderLink>
			<button id="theme-toggle" type="button" aria-label="Toggle dark mode">
				<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 18a6 6 0 1 1 0-12 6 6 0 0 1 0 12zm0-2a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM11 1h2v3h-2V1zm0 19h2v3h-2v-3zM3.515 4.929l1.414-1.414L7.05 5.636 5.636 7.05 3.515 4.93zM16.95 18.364l1.414-1.414 2.121 2.121-1.414 1.414-2.121-2.121zm2.121-14.85l1.414 1.415-2.121 2.121-1.414-1.414 2.121-2.121zM5.636 16.95l1.414 1.414-2.121 2.121-1.414-1.414 2.121-2.121zM23 11v2h-3v-2h3zM4 11v2H1v-2h3z"/></svg>
				<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M10 7a7 7 0 0 0 12 4.9v.1c0 5.523-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2h.1A6.98 6.98 0 0 0 10 7zm-6 5a8 8 0 0 0 15.062 3.762A9 9 0 0 1 8.238 4.938 7.999 7.999 0 0 0 4 12z"/></svg>
			</button>
		</div>
		<div id="cart-button-portal">
			{showCart && (
				<button type="button" class="cart-placeholder" aria-label="Shopping cart" disabled>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2m10 0c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2m-8.9-5h7.45c.75 0 1.41-.41 1.75-1.03L21 4.96 19.25 4l-3.7 7H8.53L4.27 2H1v2h2l3.6 7.59-1.35 2.44C4.52 15.37 5.48 17 7 17h12v-2H7zM12 2l4 4-4 4-1.41-1.41L12.17 7H8V5h4.17l-1.59-1.59z"/></svg>
				</button>
			)}
		</div>
		<button id="menu-toggle" type="button" aria-label="Toggle menu" class="menu-toggle">
			<svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
			<svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
		</button>
	</nav>
</header>

<script is:inline>
(function() {
	const themeBtn = document.getElementById('theme-toggle');
	if (themeBtn) {
		themeBtn.addEventListener('click', function() {
			const current = document.documentElement.getAttribute('data-theme');
			const next = current === 'dark' ? 'light' : 'dark';
			document.documentElement.setAttribute('data-theme', next);
			localStorage.setItem('theme', next);
		});
	}

	const menuBtn = document.getElementById('menu-toggle');
	const nav = document.querySelector('header nav');
	if (menuBtn && nav) {
		menuBtn.addEventListener('click', function() {
			nav.classList.toggle('open');
		});
	}
})();
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--bg-primary);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
	}
	.internal-links {
		display: flex;
		align-items: center;
		margin-left: auto;
	}
	#cart-button-portal {
		display: flex;
		align-items: center;
	}
	#cart-button-portal :global(.MuiIconButton-root) {
		background: linear-gradient(135deg, #008fff, #279214);
		color: #fff !important;
		border-radius: 8px;
		padding: 6px;
		transition: opacity 0.15s;
	}
	#cart-button-portal :global(.MuiIconButton-root:hover) {
		opacity: 0.85;
	}
	.cart-placeholder {
		background: linear-gradient(135deg, #008fff, #279214);
		border: none;
		padding: 6px;
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: default;
		border-radius: 8px;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	/* Hamburger menu button — hidden on desktop */
	.menu-toggle {
		display: none;
		background: none;
		border: none;
		padding: 0.5em;
		cursor: pointer;
		color: rgb(var(--black));
		align-items: center;
		justify-content: center;
	}
	.menu-toggle .icon-close {
		display: none;
	}
	nav.open .menu-toggle .icon-menu {
		display: none;
	}
	nav.open .menu-toggle .icon-close {
		display: block;
	}

	#theme-toggle {
		background: none;
		border: none;
		padding: 1em 0.5em;
		cursor: pointer;
		color: rgb(var(--black));
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		transition: color 0.15s;
	}
	#theme-toggle:hover {
		color: rgb(var(--black));
	}
	:global(html[data-theme="light"]) .icon-sun {
		display: none;
	}
	:global(html[data-theme="light"]) .icon-moon {
		display: block;
	}
	:global(html[data-theme="dark"]) .icon-sun {
		display: block;
	}
	:global(html[data-theme="dark"]) .icon-moon {
		display: none;
	}

	/* Mobile: collapse nav into hamburger */
	@media (max-width: 600px) {
		header {
			padding: 0.5em 1em;
		}
		.menu-toggle {
			display: flex;
		}
		.internal-links {
			display: none;
			width: 100%;
			flex-direction: column;
			align-items: stretch;
			border-top: 1px solid rgb(var(--gray-light));
			order: 99;
			margin-left: 0;
		}
		nav.open .internal-links {
			display: flex;
		}
		.internal-links a {
			padding: 0.75em 0;
			border-bottom: none;
		}
		.internal-links #theme-toggle {
			padding: 0.75em 0;
			justify-content: flex-start;
		}
		#cart-button-portal {
			margin-left: auto;
		}
	}
</style>
