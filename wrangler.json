{
	"name": "simic-systems-home",
	"compatibility_date": "2024-11-01",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"kv_namespaces": [
		{
			"binding": "PRODUCT_CACHE",
			"id": "f6256c50414546fbbcafa4f6a15664ca",
			"preview_id": "72732ce961bc4b2d825cfae2befa9d9e"
		}
	],
	"r2_buckets": [
		{
			"bucket_name": "simic-systems-tfstate",
			"binding": "simic_systems_tfstate",
			"remote": true
		}
	],
	"send_email": [
		{
			"name": "CONTACT_EMAIL",
			"destination_address": "contact@simic.systems"
		}
	]
}