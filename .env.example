# Copy to .env — loaded by Vite/Astro at build time (import.meta.env.*) and
# used to inline the PUBLIC_ vars into client-side bundles. Also read as a
# fallback by the catalog scripts in scripts/ if .dev.vars isn't present.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PUBLIC_POSTHOG_PROJECT_TOKEN=phc_...
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
